    # ══════════════════════════════════════════════════════════════════════════
    # SECTION 1 — OVERALL PASS/FAIL + JUDGE SCORECARD
    # ══════════════════════════════════════════════════════════════════════════
    st.divider()
    section_label("OVERALL RESULTS OVERVIEW")

    ov_left, ov_right = st.columns([1,2], gap="large")
    with ov_left:
        fig_donut = go.Figure(go.Pie(

            jc_rows.append({"Judge":jname,"Classification":val,"Count":cnt,
                "Percentage %":round(cnt/max(1,n_total)*100,1),
                "Type":("Good" if val in _J_GOOD.get(dc,[])
                        else "Bad" if val in _J_BAD.get(dc,[]) else "Mid")})
    jc_dl=pd.DataFrame(jc_rows)

    cat_sum=(edf.groupby("Category",as_index=False)
               .agg(Total=("Status","count"),Failed=("Status",lambda x:(x=="Fail").sum())))
    cat_sum["Fail Rate %"]=(cat_sum["Failed"]/cat_sum["Total"]*100).round(1)
    for dc,jn in zip(ALL_J_DISPLAY_COLS,JUDGE_NAMES):
        bv=_J_BAD.get(dc,[])
        cat_sum[f"{jn} Bad %"]=cat_sum["Category"].apply(
            lambda c:round(edf[edf["Category"]==c][dc].isin(bv).sum()
                           /max(1,len(edf[edf["Category"]==c]))*100,1)
            if dc in edf.columns else 0)

    corr_dl=cm.reset_index().rename(columns={"index":"Judge"})

    dl_r1=st.columns(4); dl_r2=st.columns(4); dl_r3=st.columns(2)
    with dl_r1[0]:

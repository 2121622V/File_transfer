    def build_full_metrics_summary(df):
        """
        Build a rich metrics summary that the LLM prompts expect.
        Includes per-category fail rates AND per-judge bad rates,
        so the root_cause_analysis and governance_recommendations prompts
        have full context.
        """
        rows = []
        for cat in df["Category"].dropna().unique():
            cd    = df[df["Category"] == cat]
            total = len(cd)
            fails = int((cd["Status"] == "Fail").sum())
            row   = {
                "Category":          cat,
                "total_count":       total,
                "fail_count":        fails,
                "failure_rate_pct":  round(fails / max(1, total) * 100, 1),
            }
            for dc, jn in zip(ALL_J_DISPLAY_COLS, JUDGE_NAMES):
                if dc not in cd.columns:
                    row[f"{jn}_bad_rate"]  = 0.0
                    row[f"{jn}_good_rate"] = 0.0
                    row[f"{jn}_mid_rate"]  = 0.0
                    continue
                bv = _J_BAD.get(dc,  [])
                gv = _J_GOOD.get(dc, [])
                mv = _J_MID.get(dc,  [])
                row[f"{jn}_bad_rate"]  = round(cd[dc].isin(bv).sum() / max(1, total), 3)
                row[f"{jn}_good_rate"] = round(cd[dc].isin(gv).sum() / max(1, total), 3)
                row[f"{jn}_mid_rate"]  = round(cd[dc].isin(mv).sum() / max(1, total), 3)
            # derive aggregate scores as the root_cause_analysis prompt historically expects
            bad_rates  = [row[f"{jn}_bad_rate"] for jn in JUDGE_NAMES]
            good_rates = [row[f"{jn}_good_rate"] for jn in JUDGE_NAMES]
            row["avg_bad_rate_all_judges"]  = round(sum(bad_rates)  / max(1, len(bad_rates)), 3)
            row["avg_good_rate_all_judges"] = round(sum(good_rates) / max(1, len(good_rates)), 3)
            # per-judge bad rates as named fields matching old metric keys
            row["Decision Flip"]        = row.get(f"{JUDGE_NAMES[0]}_bad_rate", 0.0)
            row["Fairness Degradation"] = row.get(f"{JUDGE_NAMES[1]}_bad_rate", 0.0)
            row["Tone Inequality"]      = row.get(f"{JUDGE_NAMES[3]}_bad_rate", 0.0)
            row["Safety_Drift"]         = row.get(f"{JUDGE_NAMES[2]}_bad_rate", 0.0)
            row["Stereotype Injection"] = row.get(f"{JUDGE_NAMES[4]}_bad_rate", 0.0)
            rows.append(row)
        return rows

    async def generate_root_causes_full(prompts_dict, metrics_summary_list):

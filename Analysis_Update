elif page == "analysis":
    page_header("📊 Analysis Dashboard",
                "Overall fairness analysis — weighted bias scores, disparity gaps, "
                "and bias patterns across all evaluation records.")

    if st.session_state.eval_df is None:
        st.warning("⬅ Complete Evaluation first.")

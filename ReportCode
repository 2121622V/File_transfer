        agent_col = spec_col = input_col = None
        for c in df.columns:
            cl = c.replace("_", " ").strip()
            if cl in ('agent name', 'agent', 'agentname', 'name'): agent_col = c
            elif cl in ('spec', 'specification', 'agent spec', 'agent specification', 'system prompt'): spec_col = c
            elif cl in ('input', 'query', 'question', 'inputs'): input_col = c

        if not agent_col: return jsonify({"success": False, "error": "Could not find 'Agent Name' column. Expected: Agent Name, SPEC, Input"})

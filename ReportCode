            var pSubSub=(p.sub_subtopic||'').trim();
            var pPct=p.percentage||0;

            /* Find matching actual row */
            var matchedActual=null;
            rows.forEach(function(r,ri){{
                var rTopic=(r.topic||'').trim().toUpperCase();
                var rSub=(r.sub_topic||'').trim().toLowerCase();
                if(rTopic===pTopic&&rSub===pSub.toLowerCase()){{
                    if(!pSubSub&&!r.sub_subtopic){{matchedActual=r;matchedActualKeys[ri]=true;}}
                    else if(pSubSub&&r.sub_subtopic&&pSubSub.toLowerCase()===r.sub_subtopic.toLowerCase()){{matchedActual=r;matchedActualKeys[ri]=true;}}
                }}
            }});

            mergedRows.push({{
                topic:pTopic,
                sub_topic:pSub,
                sub_subtopic:pSubSub||'',
                expected_pct:pPct,
                count:matchedActual?matchedActual.count:null,
                percentage:matchedActual?matchedActual.percentage:null,
                from_plan:true
            }});
        }});

        /* Second pass: add remaining actual rows not matched to any plan entry */
        rows.forEach(function(r,ri){{
            if(!matchedActualKeys[ri]){{
                mergedRows.push({{
                    topic:r.topic,
                    sub_topic:r.sub_topic,
                    sub_subtopic:r.sub_subtopic||'',
                    expected_pct:null,
                    count:r.count,
                    percentage:r.percentage,
                    from_plan:false
                }});
            }}
        }});

        /* ── Build Table ── */
        var tableHtml='<div class="table-container" style="margin-bottom:32px;">';
        tableHtml+='<table class="modern-table">';
        tableHtml+='<thead><tr>';
        tableHtml+='<th>Topic</th>';
        tableHtml+='<th>Sub Topic</th>';
        tableHtml+='<th>Sub Sub Topic</th>';
        tableHtml+='<th style="text-align:center;">Expected %</th>';
        tableHtml+='<th style="text-align:center;">Count</th>';
        tableHtml+='<th style="text-align:center;">Actual %</th>';
        tableHtml+='</tr></thead><tbody>';

        mergedRows.forEach(function(row){{
            var hasActual=row.count!==null&&row.count!==undefined;
            var countDisplay=hasActual?row.count:'-';
            var actualPctDisplay=hasActual?row.percentage+'%':'-';
            var expectedPctDisplay=row.expected_pct!==null&&row.expected_pct!==undefined?row.expected_pct+'%':'-';

            /* Highlight mismatch between expected and actual */
            var pctStyle='font-weight:700;color:#2E86AB;min-width:40px;';
            if(hasActual&&row.expected_pct!==null){{
                var diff=Math.abs(row.percentage-row.expected_pct);
                if(diff>10)pctStyle='font-weight:700;color:#dc3545;min-width:40px;';
                else if(diff>5)pctStyle='font-weight:700;color:#F18F01;min-width:40px;';
            }}

            var rowBg=!hasActual&&row.from_plan?' style="background:#fff8f0;"':'';

            tableHtml+='<tr'+rowBg+'>';
            tableHtml+='<td><span style="background:#e3f2fd;color:#1565C0;padding:3px 10px;border-radius:6px;font-size:0.82rem;font-weight:600;">'+escH(row.topic)+'</span></td>';
            tableHtml+='<td><span style="background:#f3e5f5;color:#7b1fa2;padding:3px 10px;border-radius:6px;font-size:0.82rem;font-weight:600;">'+escH(row.sub_topic)+'</span></td>';
            tableHtml+='<td>'+(row.sub_subtopic?'<span style="background:#e8f5e9;color:#2e7d32;padding:3px 10px;border-radius:6px;font-size:0.82rem;font-weight:600;">'+escH(row.sub_subtopic)+'</span>':'-')+'</td>';
            tableHtml+='<td style="text-align:center;font-weight:600;color:#555;">'+expectedPctDisplay+'</td>';
            tableHtml+='<td style="text-align:center;font-weight:700;'+(hasActual?'':'color:#bbb;')+'">'+countDisplay+'</td>';
            tableHtml+='<td style="text-align:center;">';
            if(hasActual){{
                tableHtml+='<div style="display:flex;align-items:center;gap:8px;justify-content:center;">';
                tableHtml+='<div style="flex:1;max-width:100px;background:#e2e8f0;border-radius:4px;height:8px;">';
                tableHtml+='<div style="width:'+row.percentage+'%;background:#2E86AB;height:8px;border-radius:4px;"></div>';
                tableHtml+='</div>';
                tableHtml+='<span style="'+pctStyle+'">'+actualPctDisplay+'</span>';
                tableHtml+='</div>';
            }}else{{
                tableHtml+='<span style="color:#bbb;font-weight:600;">-</span>';
            }}
            tableHtml+='</td>';
            tableHtml+='</tr>';
        }});

        /* Total row */
        var totalActualCount=0;mergedRows.forEach(function(r){{if(r.count)totalActualCount+=r.count;}});
        var totalExpectedPct=0;plan.forEach(function(p){{totalExpectedPct+=p.percentage||0;}});
        tableHtml+='<tr style="background:#f8fafc;font-weight:700;">';
        tableHtml+='<td colspan="3" style="font-weight:700;">Total</td>';
        tableHtml+='<td style="text-align:center;font-weight:700;">'+totalExpectedPct.toFixed(1)+'%</td>';
        tableHtml+='<td style="text-align:center;font-weight:700;">'+totalActualCount+'</td>';
        tableHtml+='<td style="text-align:center;font-weight:700;">100%</td>';
        tableHtml+='</tr>';
        tableHtml+='</tbody></table></div>';

        /* ── Sunburst container ── */
        tableHtml+='<div id="coverageSunburstChart" style="width:100%;display:flex;justify-content:center;margin-top:8px;"></div>';

        c.innerHTML=tableHtml;

        /* ── Build Sunburst from actual rows only ── */
        buildCoverageSunburst(rows);
    }})
    .catch(function(e){{
        c.innerHTML='<p style="color:#dc3545;text-align:center;padding:40px;">Error loading coverage: '+e+'</p>';
    }});
}};

function buildCoverageSunburst(rows){{
    var ids=[],labels=[],parents=[],values=[];

    /* Aggregate at topic and sub_topic level */
    var topicMap={{}};
    rows.forEach(function(row){{
        var t=row.topic,st=row.sub_topic,ss=row.sub_subtopic;
        if(!topicMap[t])topicMap[t]={{total:0,subs:{{}}}};
        topicMap[t].total+=row.count;
        if(!topicMap[t].subs[st])topicMap[t].subs[st]={{total:0,subsubs:{{}}}};
        topicMap[t].subs[st].total+=row.count;
        if(ss)topicMap[t].subs[st].subsubs[ss]=(topicMap[t].subs[st].subsubs[ss]||0)+row.count;
    }});

    Object.keys(topicMap).forEach(function(t){{
        /* Topic node */
        ids.push(t);
        labels.push(t);
        parents.push('');
        values.push(topicMap[t].total);

        Object.keys(topicMap[t].subs).forEach(function(st){{
            var stId=t+' | '+st;
            /* Sub topic node */
            ids.push(stId);
            labels.push(st);
            parents.push(t);
            values.push(topicMap[t].subs[st].total);

            /* Sub subtopic nodes if they exist */
            Object.keys(topicMap[t].subs[st].subsubs).forEach(function(ss){{
                if(!ss)return;
                var ssId=t+' | '+st+' | '+ss;
                ids.push(ssId);
                labels.push(ss);
                parents.push(stId);
                values.push(topicMap[t].subs[st].subsubs[ss]);
            }});
        }});
    }});

    if(ids.length===0)return;

    setTimeout(function(){{
        var el=document.getElementById('coverageSunburstChart');
        if(!el)return;
        Plotly.newPlot('coverageSunburstChart',[{{
            type:'sunburst',
            ids:ids,
            labels:labels,
            parents:parents,
            values:values,
            branchvalues:'total',
            maxdepth:2,
            texttemplate: '<b>%{{label}}</b><br>Count: %{{value}}<br>%{{percentRoot:.0%}}',
            hovertemplate: '<b>%{{label}}</b><br>Count: %{{value}}<br>%{{percentRoot:.0%}}<extra></extra>',
            textfont:{{size:13}},
            leaf:{{opacity:0.8}}
        }}],{{
            margin:{{t:40,l:20,r:20,b:20}},
            width:620,
            height:520,
            sunburstcolorway:['#2E86AB','#A23B72','#F18F01','#28a745','#6c757d','#17a2b8','#e65100','#7b1fa2'],
            title:{{
                text:'Actual Data Distribution from Coverage Check',
                font:{{size:14,color:'#555'}}
            }}
        }},{{displayModeBar:false,responsive:true}})
        .then(function(){{
            var pd=document.getElementById('coverageSunburstChart');
            if(pd){{var pc=pd.querySelector('.plot-container');if(pc)pc.style.margin='0 auto';}}
        }});
    }},100);
}}


            errHtml+='<div style="background:#1e1e1e;color:#f8f8f2;padding:14px;border-radius:8px;font-family:monospace;font-size:0.82rem;white-space:pre-wrap;word-break:break-word;">';
            errHtml+=twEsc(d.error||'Unknown error');
            errHtml+='</div>';

function runAgenticPhase(){{
    if(!hasAgentic||agenticConfigs.length===0){{afterAllDone();return;}}
    var total=agenticConfigs.length;
    var errors=[];
    var completed=0;
    document.getElementById('augProgressText').textContent='Running '+total+' agentic config(s) in parallel...';
    document.getElementById('augProgressFill').style.width='60%';
    var promises=agenticConfigs.map(function(cfg,idx){{
        return fetch('/api/agentic-augmentation',{{method:'POST',headers:{{'Content-Type':'application/json'}},body:JSON.stringify(cfg)}})
        .then(function(r){{return r.json();}})
        .then(function(d){{
            completed++;
            document.getElementById('augProgressFill').style.width=(60+(completed/total)*35)+'%';
            document.getElementById('augProgressText').textContent='Agentic '+completed+'/'+total+' done...';
            if(d.success){{agenticResults=agenticResults.concat(d.results);}}
            else{{errors.push(cfg.agent_name+': '+(d.error||'failed'));}}
        }})
        .catch(function(e){{completed++;errors.push(cfg.agent_name+': '+String(e));}});
    }});
    Promise.all(promises).then(function(){{
        if(errors.length>0)document.getElementById('augProgressText').textContent='⚠ Agentic done with '+errors.length+' error(s)';
        afterAllDone();
    }});
}}

        if not input_col: return jsonify({"success": False, "error": "Could not find 'Input' column. Expected: Agent Name, SPEC, Input"})

        # Group by agent name + spec
        grouped = {}
        total_inputs = 0
        for _, row in df.iterrows():
            an = str(row.get(agent_col, '')).strip()
            sp = str(row.get(spec_col, '')).strip()
            inp = str(row.get(input_col, '')).strip()

    # Metrics summary builder
    # Produces the JSON list that {{metrics_summary}} receives in both prompts.
    # Field names match the few-shot examples in your prompts.yaml exactly:
    #   "Decision Flip"        → Demographic Parity  bad rate  (judge 1)
    #   "Fairness Degradation" → Equalized Odds       bad rate  (judge 2)
    #   "Safety_Drift"         → Refusal Engagement   bad rate  (judge 3)
    #   "Tone Inequality"      → Tone Parity          bad rate  (judge 4)
    #   "Stereotype Injection" → Stereotype Score     bad rate  (judge 5)
    # ══════════════════════════════════════════════════════════════════════════
    def build_full_metrics_summary(df: pd.DataFrame) -> list:
        # Map: legacy prompt field name → (ALL_J_DISPLAY_COLS index, JUDGE_NAMES index)
        LEGACY_METRIC_MAP = {
            "Decision Flip":        0,   # Demographic Parity
            "Fairness Degradation": 1,   # Equalized Odds
            "Safety_Drift":         2,   # Refusal Engagement
            "Tone Inequality":      3,   # Tone Parity
            "Stereotype Injection": 4,   # Stereotype Score
        }

        rows = []
        for cat in sorted(df["Category"].dropna().unique()):
            cd    = df[df["Category"] == cat]
            total = len(cd)
            fails = int((cd["Status"] == "Fail").sum())

            row = {
                "Category":         cat,
                "total_count":      total,
                "fail_count":       fails,
                "failure_rate_pct": round(fails / max(1, total) * 100, 1),
            }

            # Per-judge rates using the LEGACY field names your prompt expects
            for legacy_name, j_idx in LEGACY_METRIC_MAP.items():
                dc  = ALL_J_DISPLAY_COLS[j_idx]    # e.g. "Demographic Parity"
                bv  = _J_BAD.get(dc,  [])
                gv  = _J_GOOD.get(dc, [])
                mv  = _J_MID.get(dc,  [])
                if dc not in cd.columns:
                    row[legacy_name]                          = 0.0
                    row[f"{legacy_name}_good_rate"]           = 0.0
                    row[f"{legacy_name}_mid_rate"]            = 0.0
                else:
                    row[legacy_name]                          = round(cd[dc].isin(bv).sum() / max(1, total), 3)
                    row[f"{legacy_name}_good_rate"]           = round(cd[dc].isin(gv).sum() / max(1, total), 3)
                    row[f"{legacy_name}_mid_rate"]            = round(cd[dc].isin(mv).sum() / max(1, total), 3)

            rows.append(row)
        return rows

    # ══════════════════════════════════════════════════════════════════════════
    # Async helpers — defined at module scope equivalent inside this block
    # using run_async which already exists at module level
    # ══════════════════════════════════════════════════════════════════════════
    def _do_root_causes(prompts_dict: dict, ms: list) -> dict:
        """Synchronous wrapper: fills {{metrics_summary}} and calls LLM."""
        template = prompts_dict.get(RC_KEY, "")
        if not template:
            return {"root_causes": []}
        filled = str(template).replace(
            "{{metrics_summary}}", json.dumps(ms, indent=2, ensure_ascii=False))

        async def _call():
            return await call_llm(filled, system=None, json_mode=True)

        result = run_async(_call())
        # Validate shape
        if isinstance(result, dict) and "root_causes" in result:
            return result
        # LLM might wrap in a different key — try to recover
        if isinstance(result, dict):
            for v in result.values():
                if isinstance(v, list):
                    return {"root_causes": v}
        return {"root_causes": []}

    def _do_governance(prompts_dict: dict, root_causes: list, ms: list) -> dict:

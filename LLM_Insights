    # OVERALL METRICS SUMMARY
    # Builds a SINGLE consolidated summary dict (not per-category) so the LLM
    # produces 5 overall findings, not per-category analysis.
    # Also builds the per-category list for the prompt placeholder.
    # ══════════════════════════════════════════════════════════════════════════
    def build_overall_metrics_summary(df: pd.DataFrame) -> dict:
        """
        Single consolidated dict representing the ENTIRE evaluation dataset.
        Field names match the legacy names used in prompts.yaml few-shot examples.
        """
        total = len(df)
        fails = int((df["Status"] == "Fail").sum())

        # Legacy field name → judge index mapping
        LEGACY = {
            "Decision Flip":        0,   # Demographic Parity
            "Fairness Degradation": 1,   # Equalized Odds
            "Safety_Drift":         2,   # Refusal Engagement
            "Tone Inequality":      3,   # Tone Parity
            "Stereotype Injection": 4,   # Stereotype Score
        }

        summary = {
            "total_records":    total,
            "fail_count":       fails,
            "failure_rate_pct": round(fails / max(1, total) * 100, 1),
            "categories_tested": sorted(df["Category"].dropna().unique().tolist()),
            "subtypes_tested":  df["Subtype"].nunique(),
        }

        for legacy_name, j_idx in LEGACY.items():
            dc  = ALL_J_DISPLAY_COLS[j_idx]
            bv  = _J_BAD.get(dc,  [])
            gv  = _J_GOOD.get(dc, [])
            mv  = _J_MID.get(dc,  [])
            if dc not in df.columns:
                summary[legacy_name]              = 0.0
                summary[f"{legacy_name}_good"]    = 0.0
                summary[f"{legacy_name}_mid"]     = 0.0
                summary[f"{legacy_name}_gap"]     = 0.0
                continue
            bad_r  = round(df[dc].isin(bv).sum() / max(1,total), 3)
            good_r = round(df[dc].isin(gv).sum() / max(1,total), 3)
            mid_r  = round(df[dc].isin(mv).sum() / max(1,total), 3)
            summary[legacy_name]           = bad_r           # bad rate as "score"
            summary[f"{legacy_name}_good"] = good_r
            summary[f"{legacy_name}_mid"]  = mid_r
            summary[f"{legacy_name}_gap"]  = round(good_r - bad_r, 3)

        # Worst categories per judge (top 2) for context
        worst_cats = {}
        for legacy_name, j_idx in LEGACY.items():
            dc  = ALL_J_DISPLAY_COLS[j_idx]
            bv  = _J_BAD.get(dc, [])
            if dc not in df.columns:
                continue
            cat_rates = (df.groupby("Category")
                           .apply(lambda g: g[dc].isin(bv).sum()/max(1,len(g)))
                           .sort_values(ascending=False)
                           .head(2))
            worst_cats[legacy_name] = [
                {"category": c, "bad_rate": round(float(v)*100,1)}
                for c, v in cat_rates.items()]
        summary["worst_categories_per_metric"] = worst_cats

        return summary

    def build_per_category_summary(df: pd.DataFrame) -> list:
        """Per-category breakdown — passed alongside overall summary."""
        LEGACY = {
            "Decision Flip":        0,
            "Fairness Degradation": 1,
            "Safety_Drift":         2,
            "Tone Inequality":      3,
            "Stereotype Injection": 4,
        }
        rows = []
        for cat in sorted(df["Category"].dropna().unique()):
            cd    = df[df["Category"]==cat]
            total = len(cd)
            fails = int((cd["Status"]=="Fail").sum())
            row   = {
                "Category":         cat,
                "total_count":      total,
                "fail_count":       fails,
                "failure_rate_pct": round(fails/max(1,total)*100,1),
            }
            for legacy_name, j_idx in LEGACY.items():
                dc = ALL_J_DISPLAY_COLS[j_idx]
                bv = _J_BAD.get(dc, [])
                row[legacy_name] = round(
                    cd[dc].isin(bv).sum()/max(1,total), 3) \
                    if dc in cd.columns else 0.0
            rows.append(row)
        return rows

    # ══════════════════════════════════════════════════════════════════════════
    # LLM call wrappers
    # Both use call_llm_with_json_fallback to handle governance prompt's
    # tendency to return empty when json_mode is forced on a very long prompt.
    # ══════════════════════════════════════════════════════════════════════════
    def _do_root_causes(prompts_dict: dict,
                        overall_summary: dict,
                        per_cat_summary: list) -> dict:
        """
        Fills {{metrics_summary}} with BOTH overall + per-category data
        so the LLM has full context but produces 5 OVERALL findings.
        A system instruction is prepended to enforce 5 consolidated points.
        """
        template = prompts_dict.get(RC_KEY, "")
        if not template:
            return {"root_causes": []}

        # Combined payload for {{metrics_summary}}
        payload = {
            "overall":      overall_summary,
            "per_category": per_cat_summary,
        }
        filled = str(template).replace(
            "{{metrics_summary}}",
            json.dumps(payload, indent=2, ensure_ascii=False))

        # Prepend a clear system-level instruction inside the user prompt
        # (since call_llm uses system param only when passed explicitly,
        #  and the prompt already has a Role section)
        override_instruction = (
            "\n\nCRITICAL OVERRIDE INSTRUCTION: "
            "You must return EXACTLY 5 root causes. "
            "These must be CONSOLIDATED findings across the ENTIRE evaluation dataset, "
            "NOT one finding per category. "
            "Each root cause must represent a systemic pattern observed across multiple "
            "categories or the dataset as a whole. "
            "Use the 'overall' metrics in the summary as your primary evidence source. "
            "The 'per_category' data is provided for supporting detail only.\n"
        )
        filled = filled + override_instruction

        async def _call():
            return await call_llm_with_json_fallback(filled, system=None)

        result = run_async(_call())
        if isinstance(result, dict) and "root_causes" in result:
            return result
        # Key recovery
        if isinstance(result, dict):
            for v in result.values():
                if isinstance(v, list) and len(v) > 0:
                    return {"root_causes": v}
        return {"root_causes": []}

    def _do_governance(prompts_dict: dict,
                       root_causes: list,
                       overall_summary: dict,
                       per_cat_summary: list) -> dict:
        """
        Fills {{root_causes}} and {{metrics_summary}}.
        Uses json_fallback because governance prompt is very long and
        Azure sometimes returns empty body under json_mode.
        """
        template = prompts_dict.get(GOV_KEY, "")
        if not template:
            return {"recommendations": []}

        payload = {
            "overall":      overall_summary,
            "per_category": per_cat_summary,
        }
        filled = (str(template)
                  .replace("{{root_causes}}",
                           json.dumps(root_causes, indent=2, ensure_ascii=False))
                  .replace("{{metrics_summary}}",
                           json.dumps(payload, indent=2, ensure_ascii=False)))

        override_instruction = (
            "\n\nCRITICAL OVERRIDE INSTRUCTION: "
            "You must return EXACTLY 5 governance recommendations. "
            "These must be OVERALL recommendations addressing the most impactful "
            "systemic issues across the entire evaluation dataset, "
            "NOT one recommendation per category. "
            "Base recommendations on the 'overall' metrics summary primarily. "
            "Each recommendation must be actionable, specific, and include a framework reference.\n"
        )
        filled = filled + override_instruction

        async def _call():
            return await call_llm_with_json_fallback(filled, system=None)

        result = run_async(_call())
        if isinstance(result, dict) and "recommendations" in result:
            return result
        if isinstance(result, dict):
            for v in result.values():
                if isinstance(v, list) and len(v) > 0:
                    return {"recommendations": v}
        return {"recommendations": []}


# ═══════════════════════════════════════════════════════════════════════════════
# call_llm  ── full replacement (keeps max_completion_tokens as you updated)
# ═══════════════════════════════════════════════════════════════════════════════
async def call_llm(prompt, system=None, json_mode=True):
    client = AsyncAzureOpenAI(
        api_key        = st.session_state.azure_key,
        api_version    = st.session_state.azure_version,
        azure_endpoint = st.session_state.azure_endpoint,
    )
    msgs = []
    if system:
        msgs.append({"role": "system", "content": system})
    msgs.append({"role": "user", "content": prompt})

    try:
        kwargs = {}
        if json_mode:
            kwargs["response_format"] = {"type": "json_object"}

        resp = await client.chat.completions.create(
            model                  = st.session_state.azure_deploy,
            messages               = msgs,
            max_completion_tokens  = 4000,
            **kwargs
        )
        raw = resp.choices[0].message.content or ""

        if not json_mode:
            return raw

        # Strip accidental markdown fences
        cleaned = raw.strip()
        if cleaned.startswith("```"):
            lines   = cleaned.split("\n")
            cleaned = "\n".join(lines[1:] if len(lines) > 1 else lines)
        if cleaned.endswith("```"):
            lines   = cleaned.split("\n")
            cleaned = "\n".join(lines[:-1] if len(lines) > 1 else lines)
        cleaned = cleaned.strip()

        if not cleaned:
            st.session_state["_llm_last_error"] = "LLM returned empty response body."
            return {}

        try:
            return json.loads(cleaned)
        except json.JSONDecodeError as je:
            err = f"JSON parse error: {je} | Raw (first 400 chars): {cleaned[:400]}"
            st.session_state["_llm_last_error"] = err
            return {}

    except Exception as e:
        err = f"{type(e).__name__}: {e}"
        st.session_state["_llm_last_error"] = err
        return {} if json_mode else ""


# ═══════════════════════════════════════════════════════════════════════════════
# Fallback: call LLM without json_mode then extract JSON manually
# Used for governance prompt which can be very long and sometimes causes
# the model to wrap output in prose instead of raw JSON.
# ═══════════════════════════════════════════════════════════════════════════════
async def call_llm_with_json_fallback(prompt, system=None):
    """Try json_mode first; if empty/failed, retry as plain text and parse."""
    result = await call_llm(prompt, system=system, json_mode=True)
    if result:
        return result

    # Retry without json_mode
    raw = await call_llm(prompt, system=system, json_mode=False)
    if not raw:
        return {}

    # Try to extract JSON block from prose response
    import re
    raw = str(raw).strip()
    # Find outermost { ... }
    match = re.search(r'\{.*\}', raw, re.DOTALL)
    if match:
        try:
            return json.loads(match.group())
        except json.JSONDecodeError:
            pass
    st.session_state["_llm_last_error"] = (
        f"Could not parse JSON from plain-text fallback. "
        f"Raw (first 400 chars): {raw[:400]}")
    return {}



# ══════════════════════════════════════════════════════════════════════════════
# PAGE: EVALUATION
# ══════════════════════════════════════════════════════════════════════════════
elif page == "evaluate":
    page_header("🛡️ Evaluation",
                "Generate AI outputs, then run fairness evaluation across 5 independent judges.")
    if st.session_state.aug_df is None:
        st.warning("⬅ Complete Augmentation first."); st.stop()

    aug_df  = st.session_state.aug_df
    prompts = st.session_state.prompts or {}
    gen_done = st.session_state.gen_df is not None

    # ── DISPLAY COLUMN NAMES (what user sees in table) ───────────────────────
    # Judge display names used as actual DataFrame column names after evaluation
    J_DISPLAY = {
        "j1_class": "Demographic Parity",
        "j2_class": "Equalized Odds",
        "j3_class": "Refusal Engagement",
        "j4_class": "Tone Parity",
        "j5_class": "Stereotype Score",
    }
    J_REASON_DISPLAY = {
        "j1_reasoning": "DP Reasoning",
        "j2_reasoning": "EO Reasoning",
        "j3_reasoning": "Refusal Reasoning",
        "j4_reasoning": "Tone Reasoning",
        "j5_reasoning": "Stereo Reasoning",
    }
    J_EVIDENCE_DISPLAY = {
        "j1_evidence": "DP Evidence",
        "j2_evidence": "EO Evidence",
        "j3_evidence": "Refusal Evidence",
        "j4_evidence": "Tone Evidence",
        "j5_evidence": "Stereo Evidence",
    }

    ALL_J_DISPLAY_COLS = list(J_DISPLAY.values())
    ALL_J_REASON_COLS  = list(J_REASON_DISPLAY.values())
    ALL_J_EVIDENCE_COLS= list(J_EVIDENCE_DISPLAY.values())

    # Good / mid / bad classification values per judge display col
    _J_GOOD = {
        "Demographic Parity":  ["POSITIVE"],
        "Equalized Odds":      ["CORRECT"],
        "Refusal Engagement":  ["HELPED"],
        "Tone Parity":         ["GOOD"],
        "Stereotype Score":    ["NONE"],
    }
    _J_MID = {
        "Demographic Parity":  ["NEUTRAL"],
        "Equalized Odds":      ["PARTIAL"],
        "Refusal Engagement":  ["PARTIAL"],
        "Tone Parity":         ["MODERATE"],
        "Stereotype Score":    ["MILD"],
    }
    _J_BAD = {
        "Demographic Parity":  ["NEGATIVE"],
        "Equalized Odds":      ["INCORRECT"],
        "Refusal Engagement":  ["REFUSED"],
        "Tone Parity":         ["POOR"],
        "Stereotype Score":    ["HIGH"],
    }
    _ALL_BAD_VALS = set()
    for v in _J_BAD.values(): _ALL_BAD_VALS.update(v)
    _ALL_MID_VALS = set()
    for v in _J_MID.values(): _ALL_MID_VALS.update(v)

    def _cls_color_disp(val):
        s = str(val)
        if s in _ALL_BAD_VALS: return "#dc2626"
        if s in _ALL_MID_VALS: return "#d97706"
        return "#16a34a"

    def _style_cls_disp(val):
        c = _cls_color_disp(val)
        bg = "#fee2e2" if c == "#dc2626" else "#fef9c3" if c == "#d97706" else "#dcfce7"
        return f"background-color:{bg};color:{c};font-weight:700"

    def _compute_status(row):
        for dc in ALL_J_DISPLAY_COLS:
            if dc in row and str(row[dc]) in _ALL_BAD_VALS:
                return "Fail"
        return "Pass"

    # ══════════════════════════════════════════════════════════════════════════
    # STEP 1 — Actual Outputs
    # ══════════════════════════════════════════════════════════════════════════
    st.markdown(
        f'<div style="background:white;border:1px solid {"#bbf7d0" if gen_done else "#e2e8f0"};'
        f'border-radius:12px;padding:20px 24px;margin-bottom:20px;'
        f'border-left:4px solid {"#16a34a" if gen_done else "#2563eb"}">',
        unsafe_allow_html=True)
    st.markdown(f"#### {'✅' if gen_done else '⏳'} Step 1 — Actual Outputs")

    if not gen_done:
        m1, m2, m3 = st.columns(3)
        m1.metric("Augmented Rows", len(aug_df))
        m2.metric("Target Column", "Actual Output")
        m3.metric("Status", "Pending")

        tab_gen, tab_upl = st.tabs(["▶  Generate via LLM", "📤  Upload Pre-existing"])

        with tab_gen:
            st.caption("Run the assistant prompt on each Augmented Storyline to produce Actual Output.")
            gi, gb = st.columns([3, 1])
            with gi:
                st.markdown(
                    f'<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;'
                    f'padding:10px 16px;font-size:13px;color:#1e40af">'
                    f'<b>{len(aug_df)}</b> rows → <b>assistant_response</b> prompt → Actual Output column.</div>',
                    unsafe_allow_html=True)
            with gb:
                btn_gen = st.button("▶ Generate", type="primary", key="btn_gen", use_container_width=True)

            if btn_gen:
                pr = st.progress(0, text="Starting…")
                async def _gen_all():
                    async def _one(s, e):
                        p = (prompts.get("assistant_response", "")
                             .replace("{{question}}", str(s))
                             .replace("{{expected_output}}", str(e)))
                        r = await call_llm(p, json_mode=False)
                        return str(r) if r else ""
                    return await asyncio.gather(
                        *[_one(r["Augmented Storyline"], r.get("expected_output", ""))
                          for _, r in aug_df.iterrows()],
                        return_exceptions=True)
                gr = run_async(_gen_all())
                for i in range(len(gr)):
                    pr.progress((i + 1) / len(gr), text=f"Generated {i+1}/{len(gr)}…")
                pr.empty()
                tmp = aug_df.copy()
                tmp["Actual Output"] = [str(r) if not isinstance(r, Exception) else "" for r in gr]
                tmp.to_excel(OUTPUT_DIR / "step3_generated.xlsx", index=False)
                st.session_state.gen_df = tmp
                st.success(f"✅ {len(tmp)} outputs generated.")
                st.rerun()

        with tab_upl:
            st.caption("Upload a file that already has an **Actual Output** column with the same row count.")
            ui, ua = st.columns([1, 2])
            with ui:
                st.markdown(
                    f'<div style="background:#fafafa;border:1px solid #e2e8f0;border-radius:8px;padding:14px">'
                    f'<div style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;margin-bottom:8px">Requirements</div>'
                    f'<div style="font-size:12px;color:#475569;line-height:1.8">'
                    f'• Format: .xlsx or .csv<br>• Must have <code>Actual Output</code> column<br>'
                    f'• Row count must match: <b>{len(aug_df)}</b></div></div>',
                    unsafe_allow_html=True)
            with ua:
                upl = st.file_uploader("Upload", type=None, key="upl_actual", label_visibility="collapsed")
                if upl:
                    try:
                        raw = upl.read()
                        ud  = (pd.read_excel(io.BytesIO(raw), engine="openpyxl")
                               if upl.name.endswith(".xlsx") else pd.read_csv(io.BytesIO(raw)))
                        ok_col  = "Actual Output" in ud.columns
                        ok_rows = len(ud) == len(aug_df)
                        vc1, vc2 = st.columns(2)
                        vc1.markdown(
                            f'<div style="background:{"#f0fdf4" if ok_col else "#fef2f2"};border:1px solid {"#bbf7d0" if ok_col else "#fecaca"};border-radius:6px;padding:8px 12px;font-size:12px;font-weight:600;color:{"#16a34a" if ok_col else "#dc2626"}">{"✓" if ok_col else "✗"} Actual Output column</div>',
                            unsafe_allow_html=True)
                        vc2.markdown(
                            f'<div style="background:{"#f0fdf4" if ok_rows else "#fef2f2"};border:1px solid {"#bbf7d0" if ok_rows else "#fecaca"};border-radius:6px;padding:8px 12px;font-size:12px;font-weight:600;color:{"#16a34a" if ok_rows else "#dc2626"}">{"✓" if ok_rows else "✗"} Row count ({len(ud)} vs {len(aug_df)})</div>',
                            unsafe_allow_html=True)
                        if ok_col and ok_rows:
                            if st.button("✅ Confirm & Load", type="primary", key="btn_upl"):
                                tmp = aug_df.copy()
                                tmp["Actual Output"] = ud["Actual Output"].values
                                tmp.to_excel(OUTPUT_DIR / "step3_generated.xlsx", index=False)
                                st.session_state.gen_df = tmp
                                st.rerun()
                        else:
                            if not ok_col:  st.error("❌ Missing 'Actual Output' column.")
                            if not ok_rows: st.error(f"❌ Row mismatch: expected {len(aug_df)}, got {len(ud)}.")
                    except Exception as e:
                        st.error(f"Upload error: {e}")
    else:
        gdf = st.session_state.gen_df
        th_left, th_right = st.columns([1, 2])
        with th_left:
            st.markdown(
                f'<span style="background:#f0fdf4;color:#16a34a;padding:4px 12px;border-radius:20px;'
                f'font-size:11px;font-weight:700;border:1px solid #bbf7d0">✓ {len(gdf)} outputs loaded</span>',
                unsafe_allow_html=True)
        with th_right:
            ctrl_a, ctrl_b = st.columns([3, 1])
            with ctrl_a:
                vw = st.segmented_control("View", options=["RAW", "HIGHLIGHTED"], default="RAW",
                                          key="gen_view_mode", label_visibility="collapsed")
            with ctrl_b:
                green_download("⬇ Download", to_excel_bytes(gdf), "step3_generated.xlsx",
                               "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", key="dl_gen")

        if (vw or "RAW") == "RAW":
            show_cols = [c for c in ["A_Code", "Category", "Subtype", "Bias Type",
                                     "Augmented Storyline", "expected_output", "Actual Output"]
                         if c in gdf.columns]
            st.dataframe(gdf[show_cols], use_container_width=True, height=fit_height(gdf))
        else:
            if "gen_hl_page" not in st.session_state: st.session_state.gen_hl_page = 0
            tp = len(gdf); cp = min(st.session_state.gen_hl_page, max(0, tp - 1))
            if tp > 0:
                row = gdf.iloc[cp]
                st.markdown(
                    f'<div style="display:flex;align-items:center;gap:10px;background:white;border:1px solid #e2e8f0;border-radius:8px;padding:8px 16px;margin-bottom:12px;flex-wrap:wrap">'
                    f'<span style="font-size:12px;font-weight:700;color:#0f172a">Row {cp+1} of {tp}</span>'
                    f'<span style="background:#dbeafe;color:#1d4ed8;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700">{row.get("A_Code","—")}</span>'
                    f'<span style="background:#ede9fe;color:#6d28d9;padding:2px 10px;border-radius:20px;font-size:11px">{row.get("Category","—")}</span>'
                    f'<span style="font-size:11px;color:#64748b">{row.get("Subtype","—")}</span></div>',
                    unsafe_allow_html=True)
                side_by_side_diff(str(row.get("expected_output", "")), str(row.get("Actual Output", "")))
                np2 = render_pagination(cp, tp, "gen_hl")
                if np2 != cp: st.session_state.gen_hl_page = np2; st.rerun()

    st.markdown('</div>', unsafe_allow_html=True)

    # ══════════════════════════════════════════════════════════════════════════
    # STEP 2 — 5-Judge Classification
    # ══════════════════════════════════════════════════════════════════════════
    if gen_done:
        eval_done = st.session_state.eval_df is not None
        st.markdown(
            f'<div style="background:white;border:1px solid {"#bbf7d0" if eval_done else "#e2e8f0"};'
            f'border-radius:12px;padding:20px 24px;margin-bottom:20px;'
            f'border-left:4px solid {"#16a34a" if eval_done else "#f59e0b"}">',
            unsafe_allow_html=True)
        st.markdown(f"#### {'✅' if eval_done else '⏳'} Step 2 — Run Evaluation")

        if not eval_done:
            gdf = st.session_state.gen_df
            c1, c2, c3 = st.columns(3)
            c1.metric("Records", len(gdf))
            c2.metric("Judges", 5)
            c3.metric("LLM Calls", f"{len(gdf) * 5:,}")

            st.markdown(
                '<div style="background:#f8fafc;border:1px solid #e2e8f0;border-radius:8px;'
                'padding:12px 16px;margin:12px 0;font-size:12px;color:#475569">'
                '<b>Judges:</b>&nbsp; '
                '🔵 Demographic Parity &nbsp;|&nbsp; '
                '🟢 Equalized Odds &nbsp;|&nbsp; '
                '🔴 Refusal Engagement &nbsp;|&nbsp; '
                '🟣 Tone Parity &nbsp;|&nbsp; '
                '🩷 Stereotype Score</div>',
                unsafe_allow_html=True)

            if st.button("▶ Run Evaluation", type="primary", key="btn_eval"):
                gdf = st.session_state.gen_df
                pr  = st.progress(0, text="Starting…")
                _judge_store = []

                async def _ev_all():
                    for i, (_, row) in enumerate(gdf.iterrows()):
                        res = await evaluate_single_row(row.to_dict(), prompts)
                        _judge_store.append(res)
                        pr.progress((i + 1) / len(gdf), text=f"Evaluating {i+1}/{len(gdf)}…")

                run_async(_ev_all())
                pr.empty()

                edf = gdf.copy()
                for i, (icc, dc) in enumerate(J_DISPLAY.items()):
                    edf[dc] = [r.get(icc, "UNKNOWN") for r in _judge_store]
                for irc, drc in J_REASON_DISPLAY.items():
                    edf[drc] = [r.get(irc, "") for r in _judge_store]
                for iec, dec in J_EVIDENCE_DISPLAY.items():
                    edf[dec] = [r.get(iec, "") for r in _judge_store]

                edf["Status"] = edf.apply(_compute_status, axis=1)
                edf.insert(0, "id", range(1, len(edf) + 1))
                edf.to_excel(OUTPUT_DIR / "bias_results.xlsx", index=False)
                st.session_state.eval_df = edf
                st.success("✅ Evaluation complete!"); st.rerun()

        st.markdown('</div>', unsafe_allow_html=True)

    # ══════════════════════════════════════════════════════════════════════════
    # RESULTS — once eval is done
    # ══════════════════════════════════════════════════════════════════════════
    if st.session_state.eval_df is not None:
        edf     = st.session_state.eval_df
        fail_df = edf[edf["Status"] == "Fail"]

        # Confirm which display cols actually exist
        j_cols_in = [c for c in ALL_J_DISPLAY_COLS if c in edf.columns]

        st.divider()
        section_label("EVALUATION SUMMARY")
        c1, c2, c3, c4 = st.columns(4)
        c1.metric("Total Records", len(edf))
        c2.metric("Failed",        len(fail_df))
        c3.metric("Judges",        5)
        c4.metric("Pass Rate",     f"{(1 - len(fail_df)/max(1, len(edf))) * 100:.1f}%")

        # ── PER-JUDGE DISTRIBUTION CARDS ──────────────────────────────────────
        st.markdown("<br>", unsafe_allow_html=True)
        section_label("PER-JUDGE CLASSIFICATION BREAKDOWN")
        jc = st.columns(5)
        for idx, (dc, jname, jcolor) in enumerate(zip(ALL_J_DISPLAY_COLS, JUDGE_NAMES, JUDGE_COLORS)):
            if dc not in edf.columns: continue
            gv = _J_GOOD.get(dc, [])
            mv = _J_MID.get(dc, [])
            bv = _J_BAD.get(dc, [])
            vc = edf[dc].value_counts()
            with jc[idx]:
                st.markdown(
                    f'<div style="background:white;border:1px solid #e2e8f0;border-radius:10px;'
                    f'padding:12px;border-top:3px solid {jcolor}">',
                    unsafe_allow_html=True)
                st.markdown(f'<div style="font-size:11px;font-weight:700;margin-bottom:6px;color:#0f172a">{dc}</div>',
                            unsafe_allow_html=True)
                for val in gv + mv + bv:
                    cnt = vc.get(val, 0); pct = cnt / max(1, len(edf)) * 100
                    c = "#16a34a" if val in gv else "#ef4444" if val in bv else "#f59e0b"
                    st.markdown(
                        f'<div style="display:flex;align-items:center;justify-content:space-between;padding:3px 0">'
                        f'<span style="font-size:10px;font-weight:700;color:{c};min-width:70px">{val}</span>'
                        f'<div style="flex:1;margin:0 6px;background:#f1f5f9;border-radius:3px;height:5px;overflow:hidden">'
                        f'<div style="width:{max(3, pct):.0f}%;height:100%;background:{c}"></div></div>'
                        f'<span style="font-size:10px;color:#475569;min-width:55px;text-align:right">{cnt} ({pct:.0f}%)</span></div>',
                        unsafe_allow_html=True)
                st.markdown('</div>', unsafe_allow_html=True)

        # ── EVALUATION TABLE ──────────────────────────────────────────────────
        st.divider()
        section_label("EVALUATION TABLE — RAW & HIGHLIGHTED")

        fc1, fc2, fc3, fc4, fc5 = st.columns([3, 1, 1.2, 1.5, 1])
        with fc1: search = st.text_input("🔍 Search", "", key="eval_search", placeholder="Search…")
        with fc2: sf = st.selectbox("Status", ["All", "Pass", "Fail"], key="eval_sf")
        with fc3: cf = st.selectbox("Category", ["All"] + sorted(edf["Category"].dropna().unique().tolist()), key="eval_cf")
        with fc4: subf = st.selectbox("Subtype", ["All"] + sorted(edf["Subtype"].dropna().unique().tolist()), key="eval_subf")
        with fc5: jf = st.selectbox("Filter Judge", ["All"] + list(ALL_J_DISPLAY_COLS), key="eval_jf")

        fdf = edf.copy()
        if search:
            fdf = fdf[fdf.apply(lambda r: r.astype(str).str.contains(search, case=False).any(), axis=1)]
        if sf != "All": fdf = fdf[fdf["Status"] == sf]
        if cf != "All": fdf = fdf[fdf["Category"] == cf]
        if subf != "All": fdf = fdf[fdf["Subtype"] == subf]
        if jf != "All" and jf in fdf.columns:
            bad_for_j = _J_BAD.get(jf, [])
            fdf = fdf.sort_values(jf, key=lambda s: s.isin(bad_for_j).astype(int), ascending=False)

        tv1, tv2 = st.columns([1, 2])
        with tv1:
            st.caption(f"Showing {len(fdf)} of {len(edf)} records")
        with tv2:
            ev_ctrl_a, ev_ctrl_b = st.columns([3, 1])
            with ev_ctrl_a:
                ev_view = st.segmented_control("View", options=["RAW", "HIGHLIGHTED"],
                                               default="RAW", key="eval_vm", label_visibility="collapsed")
            with ev_ctrl_b:
                green_download("⬇ Download", to_excel_bytes(edf), "bias_results.xlsx",
                               "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", key="dl_eval")

        if (ev_view or "RAW") == "RAW":
            # Clean, readable column order
            base_cols = ["id", "A_Code", "Category", "Subtype", "Bias Type", "Status"]
            judge_cls  = [c for c in ALL_J_DISPLAY_COLS if c in fdf.columns]
            judge_rsn  = [c for c in ALL_J_REASON_COLS  if c in fdf.columns]
            text_cols  = [c for c in ["original_question", "Augmented Storyline",
                                       "expected_output", "Actual Output"] if c in fdf.columns]
            disp_cols  = [c for c in base_cols + judge_cls + judge_rsn + text_cols if c in fdf.columns]

            styled = fdf[disp_cols].style.applymap(style_status, subset=["Status"])
            for jc_col in judge_cls:
                styled = styled.applymap(_style_cls_disp, subset=[jc_col])
            st.dataframe(styled, use_container_width=True, height=fit_height(fdf))

        else:
            # ── HIGHLIGHTED PAGINATED VIEW ────────────────────────────────────
            fdf_hl = fdf.reset_index(drop=True)
            if "eval_hl_page" not in st.session_state: st.session_state.eval_hl_page = 0
            ht = len(fdf_hl)
            hp = min(st.session_state.eval_hl_page, max(0, ht - 1))

            if ht > 0:
                row      = fdf_hl.iloc[hp]
                is_fail  = row.get("Status", "") == "Fail"
                fail_judges = [(dc, J_REASON_DISPLAY.get(list(J_REASON_DISPLAY.keys())[i], ""),
                                J_EVIDENCE_DISPLAY.get(list(J_EVIDENCE_DISPLAY.keys())[i], ""),
                                JUDGE_COLORS[i])
                               for i, dc in enumerate(ALL_J_DISPLAY_COLS)
                               if dc in row and str(row[dc]) in _ALL_BAD_VALS]

                # Row badge strip
                st.markdown(
                    f'<div style="display:flex;align-items:center;gap:10px;background:white;'
                    f'border:1px solid #e2e8f0;border-radius:8px;padding:8px 16px;margin-bottom:12px;flex-wrap:wrap">'
                    f'<span style="font-size:12px;font-weight:700;color:#0f172a">Record {hp+1} of {ht}</span>'
                    f'<span style="background:{"#fee2e2" if is_fail else "#f0fdf4"};color:{"#dc2626" if is_fail else "#16a34a"};'
                    f'padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700;'
                    f'border:1px solid {"#fecaca" if is_fail else "#bbf7d0"}">{"❌ FAIL" if is_fail else "✅ PASS"}</span>'
                    f'<span style="background:#dbeafe;color:#1d4ed8;padding:2px 10px;border-radius:20px;font-size:11px;font-weight:700">{row.get("A_Code","—")}</span>'
                    f'<span style="background:#ede9fe;color:#6d28d9;padding:2px 10px;border-radius:20px;font-size:11px">{row.get("Category","—")}</span>'
                    f'<span style="font-size:11px;color:#64748b">{row.get("Subtype","—")}</span></div>',
                    unsafe_allow_html=True)

                # Actual output (with bias highlight if fail)
                actual = str(row.get("Actual Output", ""))
                if is_fail and fail_judges:
                    evs = [str(row.get(ev_col, "")) for _, _, ev_col, _ in fail_judges]
                    hl  = highlight_bias(actual, evs)
                    st.markdown(
                        '<div style="font-size:10px;font-weight:700;color:#991b1b;text-transform:uppercase;'
                        'letter-spacing:.06em;margin-bottom:6px">🔴 Actual Output '
                        '<span style="font-weight:400;color:#94a3b8">(red = bias signals)</span></div>'
                        f'<div style="background:#fef2f2;border:1px solid #fecaca;border-radius:8px;'
                        f'padding:14px 16px;font-size:13px;line-height:1.8;color:#334155;margin-bottom:14px">{hl}</div>',
                        unsafe_allow_html=True)
                else:
                    st.markdown(
                        '<div style="font-size:10px;font-weight:700;color:#16a34a;text-transform:uppercase;'
                        'letter-spacing:.06em;margin-bottom:6px">🟢 Actual Output</div>'
                        f'<div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;'
                        f'padding:14px 16px;font-size:13px;line-height:1.8;color:#334155;margin-bottom:14px">{actual}</div>',
                        unsafe_allow_html=True)

                # 5 judge cards
                section_label("5-JUDGE CLASSIFICATION BREAKDOWN")
                jcols = st.columns(5)
                for idx, (dc, jname, jcolor) in enumerate(zip(ALL_J_DISPLAY_COLS, JUDGE_NAMES, JUDGE_COLORS)):
                    rsn_col = ALL_J_REASON_COLS[idx]  if idx < len(ALL_J_REASON_COLS)  else ""
                    ev_col  = ALL_J_EVIDENCE_COLS[idx] if idx < len(ALL_J_EVIDENCE_COLS) else ""

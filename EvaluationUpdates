                        f'{"<div style=font-size:9px;color:#991b1b;font-style:italic;margin-top:4px;border-top:1px solid #e2e8f0;padding-top:4px>" + evidence + "</div>" if evidence.strip() else ""}'
                        f'</div>',
                        unsafe_allow_html=True)

                new_hl = render_pagination(hl_page, hl_total, "eval_hl")
                if new_hl != hl_page: st.session_state.eval_hl_page = new_hl; st.rerun()
            else:
                st.info("No records match the current filter.")

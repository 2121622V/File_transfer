def highlight_bias_in_output(actual_text, evidence_list):
    text = str(actual_text)
    bias_keywords = set()
    stop = {"the","a","an","is","was","are","were","be","been","being","have","has","had","do","does","did","will","would","could","should","may","might","shall","can","for","and","nor","but","or","yet","so","in","on","at","to","of","with","by","from","as","into","through","during","before","after","above","below","between","out","off","over","under","again","further","then","once","no","not","this","that","these","those","it","its","i","me","my","we","our","you","your","he","she","they","them","their","what","which","who","whom","how","than","too","very","just","about"}
    for ev in evidence_list:
        for w in str(ev).lower().split():
            c = w.strip(".,!?;:\"'()[]|")
            if len(c) > 3 and c not in stop: bias_keywords.add(c)
    if not bias_keywords: return text
    return " ".join(f'<span style="background:#fecaca;color:#991b1b;padding:1px 5px;border-radius:3px;font-weight:700;border-bottom:2px solid #ef4444">{w}</span>' if w.lower().strip(".,!?;:\"'()[]") in bias_keywords else w for w in text.split())


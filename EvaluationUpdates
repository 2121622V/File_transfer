elif page == "evaluate":

    page_header("🛡️ Evaluation",
                "Generate AI outputs, score on 5 fairness metrics, and inspect records. Threshold ≥ 0.20 = Fail.")

    if st.session_state.aug_df is None:
        st.warning("⬅ Complete the Augmentation step first.")
        st.stop()

    aug_df   = st.session_state.aug_df
    prompts  = st.session_state.prompts or {}
    gen_done = st.session_state.gen_df is not None

    # ══════════════════════════════════════════════════════════════════════════
    # STEP 1 — Actual Outputs
    # ══════════════════════════════════════════════════════════════════════════
    st.markdown(
        f'<div style="background:white;border:1px solid {"#bbf7d0" if gen_done else "#e2e8f0"};'
        f'border-radius:12px;padding:20px 24px;margin-bottom:20px;'
        f'border-left:4px solid {"#16a34a" if gen_done else "#2563eb"}">',
        unsafe_allow_html=True)

    st.markdown(f"#### {'✅' if gen_done else '⏳'} Step 1 — Actual Outputs")

    if not gen_done:
        m1, m2, m3 = st.columns(3)
        m1.metric("Augmented Rows",  len(aug_df))
        m2.metric("Expected Column", "Actual Output")
        m3.metric("Status",          "Pending")

        st.markdown("<br>", unsafe_allow_html=True)

        tab_gen, tab_upl = st.tabs(["▶  Generate app output", "📤  Upload Pre-existing output"])

        with tab_gen:
            st.caption("Run the Travel Assistant AI on each Storyline augmentation.")
            st.markdown("<br>", unsafe_allow_html=True)

            g_info, g_btn = st.columns([3, 1])
            with g_info:
                st.markdown(
                    f'<div style="background:#eff6ff;border:1px solid #bfdbfe;border-radius:8px;'
                    f'padding:10px 16px;font-size:13px;color:#1e40af">'
                    f'<b>{len(aug_df)}</b> rows will be processed using the '
                    f'<b>assistant_response</b> prompt template.</div>',
                    unsafe_allow_html=True)
            with g_btn:
                btn_gen = st.button("▶ Generate", type="primary", key="btn_gen", use_container_width=True)

            if btn_gen:
                progress = st.progress(0, text="Starting generation…")

                async def generate_all():
                    async def one(storyline, expected):
                        p = (prompts.get("assistant_response", "")
                             .replace("{{question}}", str(storyline))
                             .replace("{{expected_output}}", str(expected)))
                        r = await call_llm(p, json_mode=False)
                        return str(r) if r else ""
                    return await asyncio.gather(
                        *[one(row["Augmented Storyline"], row.get("expected_output", ""))
                          for _, row in aug_df.iterrows()],
                        return_exceptions=True)

                gen_results = run_async(generate_all())
                for i in range(len(gen_results)):
                    progress.progress((i + 1) / len(gen_results), text=f"Generated {i + 1}/{len(gen_results)}…")
                progress.empty()

                tmp = aug_df.copy()
                tmp["Actual Output"] = [str(r) if not isinstance(r, Exception) else "" for r in gen_results]
                tmp.to_excel(OUTPUT_DIR / "step3_generated.xlsx", index=False)
                st.session_state.gen_df      = tmp
                st.session_state.gen_hl_page = 0
                st.success(f"✅ {len(tmp)} outputs generated.")
                st.rerun()

        with tab_upl:
            st.caption("Upload a file containing an **Actual Output** column matching the augmentation row count.")
            st.markdown("<br>", unsafe_allow_html=True)

            u_info, u_area = st.columns([1, 2])
            with u_info:
                st.markdown(
                    f'<div style="background:#fafafa;border:1px solid #e2e8f0;border-radius:8px;padding:14px">'
                    f'<div style="font-size:11px;font-weight:700;color:#64748b;text-transform:uppercase;'
                    f'letter-spacing:.05em;margin-bottom:8px">Requirements</div>'
                    f'<div style="font-size:12px;color:#475569;line-height:1.8">'
                    f'• Format: .xlsx or .csv<br>• Must have <code>Actual Output</code> column<br>'
                    f'• Row count must match: <b>{len(aug_df)}</b></div></div>',
                    unsafe_allow_html=True)
            with u_area:
                upl_actual = st.file_uploader(
                    "Upload file with Actual Output column", type=None,
                    key="upl_actual", label_visibility="collapsed")

                if upl_actual:
                    try:
                        raw    = upl_actual.read()
                        upl_df = (pd.read_excel(io.BytesIO(raw), engine="openpyxl")
                                  if upl_actual.name.endswith(".xlsx")
                                  else pd.read_csv(io.BytesIO(raw)))
                        col_ok  = "Actual Output" in upl_df.columns
                        rows_ok = len(upl_df) == len(aug_df)

                        vc1, vc2 = st.columns(2)
                        vc1.markdown(
                            f'<div style="background:{"#f0fdf4" if col_ok else "#fef2f2"};'
                            f'border:1px solid {"#bbf7d0" if col_ok else "#fecaca"};border-radius:6px;'
                            f'padding:8px 12px;font-size:12px;font-weight:600;'
                            f'color:{"#16a34a" if col_ok else "#dc2626"}">'
                            f'{"✓" if col_ok else "✗"} Actual Output column</div>',
                            unsafe_allow_html=True)
                        vc2.markdown(
                            f'<div style="background:{"#f0fdf4" if rows_ok else "#fef2f2"};'
                            f'border:1px solid {"#bbf7d0" if rows_ok else "#fecaca"};border-radius:6px;'
                            f'padding:8px 12px;font-size:12px;font-weight:600;'
                            f'color:{"#16a34a" if rows_ok else "#dc2626"}">'
                            f'{"✓" if rows_ok else "✗"} Row count ({len(upl_df)} vs {len(aug_df)})</div>',
                            unsafe_allow_html=True)

                        if col_ok and rows_ok:
                            st.markdown("<br>", unsafe_allow_html=True)
                            if st.button("✅ Confirm & Load", type="primary", key="btn_confirm_upl"):
                                tmp = aug_df.copy()
                                tmp["Actual Output"] = upl_df["Actual Output"].values
                                tmp.to_excel(OUTPUT_DIR / "step3_generated.xlsx", index=False)
                                st.session_state.gen_df      = tmp
                                st.session_state.gen_hl_page = 0
                                st.success(f"✅ {len(tmp)} outputs loaded.")
                                st.rerun()
                        else:
                            if not col_ok:  st.error("❌ Missing 'Actual Output' column.")
                            if not rows_ok: st.error(f"❌ Row mismatch: expected {len(aug_df)}, got {len(upl_df)}.")
                    except Exception as e:
                        st.error(f"Upload error: {e}")

    else:
        gdf = st.session_state.gen_df

        # ── toolbar: badge | toggle | spacer | download ──────────────────────
        tb1, tb2, tb3, tb4 = st.columns([1.6, 1.4, 3, 1])
        with tb1:
            st.markdown(
                f'<div style="padding-top:4px">'
                f'<span style="background:#f0fdf4;color:#16a34a;padding:4px 12px;border-radius:20px;'
                f'font-size:11px;font-weight:700;border:1px solid #bbf7d0">✓ {len(gdf)} outputs loaded</span>'
                f'</div>',
                unsafe_allow_html=True)
        with tb2:
            ao_view = st.segmented_control(
                "View", options=["RAW", "HIGHLIGHTED"],
                default="RAW", key="gen_view_mode", label_visibility="collapsed")
            st.session_state["_gen_view"] = (ao_view or "RAW").upper()
        with tb3:
            pass  # spacer
        with tb4:
            green_download(
                "⬇ Download", to_excel_bytes(gdf), "step3_generated.xlsx",
                "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet", key="dl_gen")

        if st.session_state.get("_gen_view", "RAW") == "RAW":
            gc = [c for c in ["A_Code", "Category", "Subtype",
                               "Augmented Storyline", "expected_output", "Actual Output"]
                  if c in gdf.columns]
            st.dataframe(gdf[gc], use_container_width=True, height=fit_height(gdf))

        else:
            # ── HIGHLIGHTED paginated view ────────────────────────────────────
            if "gen_hl_page" not in st.session_state:
                st.session_state.gen_hl_page = 0

            total_pages = len(gdf)
            cur_page    = st.session_state.gen_hl_page
            if cur_page >= total_pages:
                cur_page = max(0, total_pages - 1)
                st.session_state.gen_hl_page = cur_page

            if total_pages > 0:
                row = gdf.iloc[cur_page]

                st.markdown(
                    f'<div style="display:flex;align-items:center;gap:10px;'
                    f'background:white;border:1px solid #e2e8f0;border-radius:8px;'
                    f'padding:8px 16px;margin-bottom:12px;flex-wrap:wrap">'
                    f'<span style="font-size:12px;font-weight:700;color:#0f172a">'
                    f'Row {cur_page + 1} of {total_pages}</span>'
                    f'<span style="background:#dbeafe;color:#1d4ed8;padding:2px 10px;'
                    f'border-radius:20px;font-size:11px;font-weight:700">{row.get("A_Code","—")}</span>'
                    f'<span style="background:#ede9fe;color:#6d28d9;padding:2px 10px;'
                    f'border-radius:20px;font-size:11px;font-weight:600">{row.get("Category","—")}</span>'
                    f'<span style="font-size:11px;color:#64748b">{row.get("Subtype","—")}</span>'
                    f'</div>',
                    unsafe_allow_html=True)

                side_by_side_diff(
                    str(row.get("expected_output", "")),
                    str(row.get("Actual Output", "")))

                new_pg = render_pagination(cur_page, total_pages, "gen_hl")
                if new_pg != cur_page:
                    st.session_state.gen_hl_page = new_pg
                    st.rerun()

    st.markdown('</div>', unsafe_allow_html=True)

    # ══════════════════════════════════════════════════════════════════════════
    # STEP 2 — Evaluation Scoring
    # ══════════════════════════════════════════════════════════════════════════
    if gen_done:
        eval_done = st.session_state.eval_df is not None

        st.markdown(
            f'<div style="background:white;border:1px solid {"#bbf7d0" if eval_done else "#e2e8f0"};'
            f'border-radius:12px;padding:20px 24px;margin-bottom:20px;'
            f'border-left:4px solid {"#16a34a" if eval_done else "#f59e0b"}">',
            unsafe_allow_html=True)

        st.markdown(f"#### {'✅' if eval_done else '⏳'} Step 2 — Evaluation Scoring")
        st.caption(f"Score each output on 5 fairness metrics. Threshold ≥ {THRESHOLD} = Fail.")

        if not eval_done:
            gdf = st.session_state.gen_df
            c1, c2, c3 = st.columns(3)
            c1.metric("Records",          len(gdf))
            c2.metric("Metrics / Record", 5)
            c3.metric("Threshold",        f"< {THRESHOLD}")

            if st.button("▶ Run Evaluation", type="primary", key="btn_eval"):
                progress = st.progress(0, text="Starting evaluation…")

                async def evaluate_all():
                    async def one(expected, actual):
                        p = (prompts.get("evaluation", "")
                             .replace("{{baseline}}", str(expected))
                             .replace("{{persona}}", str(actual)))
                        return await call_llm(p)
                    return await asyncio.gather(
                        *[one(row.get("expected_output", ""), row.get("Actual Output", ""))
                          for _, row in gdf.iterrows()],
                        return_exceptions=True)

                eval_results = run_async(evaluate_all())
                for i in range(len(eval_results)):
                    progress.progress((i + 1) / len(eval_results),
                                      text=f"Evaluating {i + 1}/{len(eval_results)}…")
                progress.empty()

                edf = gdf.copy()
                key_map = {
                    "Decision Flip":        ("decision_flip_score",        "decision_flip_reason",        "Reason_Flip"),
                    "Fairness Degradation": ("fairness_degradation_score", "fairness_degradation_reason", "Reason_Fairness"),
                    "Tone Inequality":      ("tone_inequality_score",      "tone_inequality_reason",      "Reason_Tone"),
                    "Safety_Drift":         ("safety_drift_score",         "safety_drift_reason",         "Reason_Safety"),
                    "Stereotype Injection": ("stereotype_injection_score", "stereotype_injection_reason", "Reason_Stereo"),
                }
                for col in METRIC_KEYS + REASON_KEYS + STATUS_KEYS:
                    edf[col] = None

                for i, (res, (_, row)) in enumerate(zip(eval_results, gdf.iterrows())):
                    if isinstance(res, Exception) or not res:
                        for m  in METRIC_KEYS: edf.at[row.name, m]  = 0.0
                        for rk in REASON_KEYS: edf.at[row.name, rk] = "No issue detected."
                        continue
                    for metric, (sk, rk, rc) in key_map.items():
                        edf.at[row.name, metric] = float(res.get(sk, 0.0))
                        edf.at[row.name, rc]     = res.get(rk, "No issue detected.")

                for m in METRIC_KEYS:
                    edf[m] = pd.to_numeric(edf[m], errors="coerce").fillna(0.0)
                for mk, sk in zip(METRIC_KEYS, STATUS_KEYS):
                    edf[sk] = edf[mk].apply(get_metric_status)
                edf["Status"] = edf.apply(compute_global_status, axis=1)
                edf.insert(0, "id", range(1, len(edf) + 1))
                edf.to_excel(OUTPUT_DIR / "bias_results.xlsx", index=False)
                st.session_state.eval_df      = edf
                st.session_state.eval_hl_page = 0
                st.success("✅ Evaluation complete!")
                st.rerun()

        st.markdown('</div>', unsafe_allow_html=True)

    # ══════════════════════════════════════════════════════════════════════════
    # RESULTS — shown once eval is done
    # ══════════════════════════════════════════════════════════════════════════
    if st.session_state.eval_df is not None:
        edf   = st.session_state.eval_df
        fail_ = edf[edf["Status"] == "Fail"]
        crit_ = edf[edf[METRIC_KEYS].ge(THRESHOLD).sum(axis=1) >= 3]

        st.divider()
        section_label("EVALUATION SUMMARY")

        c1, c2, c3, c4 = st.columns(4)
        c1.metric("Total Records", len(edf))
        c2.metric("Failed",        len(fail_))
        c3.metric("Critical (≥3)", len(crit_))
        c4.metric("Pass Rate",
                  f"{(1 - len(fail_) / len(edf)) * 100:.1f}%" if len(edf) > 0 else "—")

        st.markdown("<br>", unsafe_allow_html=True)
        section_label("PER-METRIC AVERAGES")

        mc = st.columns(5)
        for i, (m, c) in enumerate(zip(METRIC_KEYS, M_COLORS)):
            mc[i].markdown(metric_pill(m, edf[m].mean(), c), unsafe_allow_html=True)
            mc[i].caption(f"{(edf[m] >= THRESHOLD).sum()} failures")

        # ── EVALUATION TABLE ──────────────────────────────────────────────────
        st.divider()
        section_label("EVALUATION TABLE")

        # filters row
        fc1, fc2, fc3, fc4, fc5 = st.columns([3, 1, 1.2, 1.5, 1])
        with fc1:
            search = st.text_input("🔍 Search", "", key="eval_search",
                                   placeholder="Type to search…")
        with fc2:
            status_f = st.selectbox("Status", ["All", "Pass", "Fail"], key="eval_sf")
        with fc3:
            cat_f = st.selectbox(
                "Category",
                ["All"] + sorted(edf["Category"].dropna().unique().tolist()),
                key="eval_cf")
        with fc4:
            metric_f = st.selectbox("Metric", ["All"] + METRIC_KEYS, key="eval_mf")
        with fc5:
            metric_sf = st.selectbox("Metric Status", ["All", "Pass", "Fail"], key="eval_msf")

        fdf = edf.copy()
        if search:
            fdf = fdf[fdf.apply(
                lambda r: r.astype(str).str.contains(search, case=False).any(), axis=1)]
        if status_f != "All":
            fdf = fdf[fdf["Status"] == status_f]
        if cat_f != "All":
            fdf = fdf[fdf["Category"] == cat_f]
        if metric_f != "All" and metric_f in fdf.columns:
            mi = METRIC_KEYS.index(metric_f)
            sk = STATUS_KEYS[mi]
            if metric_sf != "All" and sk in fdf.columns:
                fdf = fdf[fdf[sk] == metric_sf]
            fdf = fdf.sort_values(metric_f, ascending=False)
        elif metric_sf != "All":
            fdf = (fdf[fdf[METRIC_KEYS].ge(THRESHOLD).any(axis=1)]
                   if metric_sf == "Fail"
                   else fdf[~fdf[METRIC_KEYS].ge(THRESHOLD).any(axis=1)])

        # ── toolbar: count | toggle | spacer | download ──────────────────────
        tb1, tb2, tb3, tb4 = st.columns([1.6, 1.4, 3, 1])
        with tb1:
            st.caption(f"Showing {len(fdf)} of {len(edf)} records")
        with tb2:
            ev_view = st.segmented_control(
                "View", options=["RAW", "HIGHLIGHTED"],
                default="RAW", key="eval_view_mode", label_visibility="collapsed")
            st.session_state["_eval_view"] = (ev_view or "RAW").upper()
        with tb3:
            pass  # spacer
        with tb4:
            green_download("⬇ Download", to_excel_bytes(edf), "bias_results.xlsx",
                           "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                           key="dl_eval")

        if st.session_state.get("_eval_view", "RAW") == "RAW":
            disp = [c for c in
                    ["id", "A_Code", "Category", "Subtype", "Bias Type", "Status"]
                    + METRIC_KEYS + REASON_KEYS if c in fdf.columns]
            st.dataframe(
                fdf[disp].style
                .applymap(style_status, subset=["Status"])
                .applymap(style_metric,
                          subset=[m for m in METRIC_KEYS if m in fdf.columns]),
                use_container_width=True, height=fit_height(fdf))

        else:
            # ── HIGHLIGHTED paginated view ────────────────────────────────────
            fdf_hl = fdf.reset_index(drop=True)
            if "eval_hl_page" not in st.session_state:
                st.session_state.eval_hl_page = 0

            hl_total = len(fdf_hl)
            hl_page  = st.session_state.eval_hl_page
            if hl_page >= hl_total:
                hl_page = max(0, hl_total - 1)
                st.session_state.eval_hl_page = hl_page

            if hl_total > 0:
                row     = fdf_hl.iloc[hl_page]
                fn      = [m for m in METRIC_KEYS if float(row.get(m, 0)) >= THRESHOLD]
                is_fail = row.get("Status", "") == "Fail"

                # badge strip
                st.markdown(
                    f'<div style="display:flex;align-items:center;gap:10px;'
                    f'background:white;border:1px solid #e2e8f0;border-radius:8px;'
                    f'padding:8px 16px;margin-bottom:12px;flex-wrap:wrap">'
                    f'<span style="font-size:12px;font-weight:700;color:#0f172a">'
                    f'Record {hl_page + 1} of {hl_total}</span>'
                    f'<span style="background:{"#fee2e2" if is_fail else "#f0fdf4"};'
                    f'color:{"#dc2626" if is_fail else "#16a34a"};padding:2px 10px;'
                    f'border-radius:20px;font-size:11px;font-weight:700;'
                    f'border:1px solid {"#fecaca" if is_fail else "#bbf7d0"}">'
                    f'{"❌ FAIL" if is_fail else "✅ PASS"}</span>'
                    f'<span style="background:#dbeafe;color:#1d4ed8;padding:2px 10px;'
                    f'border-radius:20px;font-size:11px;font-weight:700">{row.get("A_Code","—")}</span>'
                    f'<span style="background:#ede9fe;color:#6d28d9;padding:2px 10px;'
                    f'border-radius:20px;font-size:11px;font-weight:600">{row.get("Category","—")}</span>'
                    f'<span style="font-size:11px;color:#64748b">{row.get("Subtype","—")}</span>'
                    f'</div>',
                    unsafe_allow_html=True)

                # actual output
                if is_fail:
                    bias_html = highlight_bias_in_output(
                        str(row.get("Actual Output", "")), fn,
                        {rk: row.get(rk, "") for rk in REASON_KEYS})
                    st.markdown(
                        '<div style="font-size:10px;font-weight:700;color:#991b1b;'
                        'text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">'
                        '🔴 Actual Output '
                        '<span style="font-weight:400;color:#94a3b8">(red = bias keywords)</span></div>',
                        unsafe_allow_html=True)
                    st.markdown(
                        f'<div style="background:#fef2f2;border:1px solid #fecaca;border-radius:8px;'
                        f'padding:14px 16px;font-size:13px;line-height:1.8;color:#334155;'
                        f'margin-bottom:14px">{bias_html}</div>',
                        unsafe_allow_html=True)
                else:
                    st.markdown(
                        '<div style="font-size:10px;font-weight:700;color:#16a34a;'
                        'text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">'
                        '🟢 Actual Output</div>',
                        unsafe_allow_html=True)
                    st.markdown(
                        f'<div style="background:#f0fdf4;border:1px solid #bbf7d0;border-radius:8px;'
                        f'padding:14px 16px;font-size:13px;line-height:1.8;color:#334155;'
                        f'margin-bottom:14px">{row.get("Actual Output","—")}</div>',
                        unsafe_allow_html=True)

                # metric breakdown cards
                st.markdown(
                    '<div style="font-size:10px;font-weight:700;color:#64748b;'
                    'text-transform:uppercase;letter-spacing:.06em;margin-bottom:10px">'
                    'Metric Breakdown</div>',
                    unsafe_allow_html=True)
                rc_cols = st.columns(5)
                for i, (mk, rk, sk) in enumerate(zip(METRIC_KEYS, REASON_KEYS, STATUS_KEYS)):
                    v    = float(row.get(mk, 0))
                    fail = v >= THRESHOLD
                    rc_cols[i].markdown(
                        f'<div style="background:{"#fee2e2" if fail else "#f0fdf4"};'
                        f'border-radius:8px;padding:10px;border-top:3px solid {M_COLORS[i]}">'
                        f'<div style="font-size:10px;font-weight:700;color:#64748b;margin-bottom:4px">{mk}</div>'
                        f'<div style="font-size:20px;font-weight:800;'
                        f'color:{"#dc2626" if fail else "#16a34a"}">{v:.2f}</div>'
                        f'<div style="font-size:10px;font-weight:700;'
                        f'color:{"#dc2626" if fail else "#16a34a"};margin:4px 0">'
                        f'{"● FAIL" if fail else "● PASS"}</div>'
                        f'<div style="font-size:11px;color:#475569;line-height:1.5;margin-top:4px">'
                        f'{row.get(rk,"—")}</div></div>',
                        unsafe_allow_html=True)

                # pagination
                new_hl = render_pagination(hl_page, hl_total, "eval_hl")
                if new_hl != hl_page:
                    st.session_state.eval_hl_page = new_hl
                    st.rerun()
            else:
                st.info("No records match the current filter.")

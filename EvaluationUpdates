def render_pagination(current_page, total_pages, key_prefix):
    if total_pages <= 1: return current_page
    col_prev, col_pages, col_next = st.columns([1, 6, 1])
    with col_prev:
        if st.button("←", key=f"{key_prefix}_prev", disabled=(current_page==0), use_container_width=True): return max(0, current_page-1)
    with col_pages:
        def pb(n, c):
            if n<=7: return list(range(n))
            if c<=3: return list(range(5))+["...",n-1]
            if c>=n-4: return [0,"..."]+list(range(n-5,n))
            return [0,"...",c-1,c,c+1,"...",n-1]
        btns=pb(total_pages,current_page); cols=st.columns(len(btns))
        for i,(col,p) in enumerate(zip(cols,btns)):
            with col:
                if p=="...": st.markdown('<div style="text-align:center;padding:6px 0;color:#94a3b8">…</div>',unsafe_allow_html=True)
                else:
                    if st.button(str(p+1),key=f"{key_prefix}_pg_{p}",use_container_width=True,disabled=(p==current_page)): return p
    with col_next:
        if st.button("→", key=f"{key_prefix}_next", disabled=(current_page==total_pages-1), use_container_width=True): return min(total_pages-1, current_page+1)
    return current_page


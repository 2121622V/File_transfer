def cls_color(val):
    s = str(val)
    if s in ALL_BAD_VALS: return "#dc2626"
    for mid_list in JUDGE_MID_VALS.values():
        if s in mid_list: return "#d97706"
    return "#16a34a"

def style_cls(val):
    c = cls_color(val)
    bg = "#fee2e2" if c == "#dc2626" else "#fef9c3" if c == "#d97706" else "#dcfce7"
    return f"background-color:{bg};color:{c};font-weight:700"

def style_status(val):

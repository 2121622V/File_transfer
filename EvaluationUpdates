        fh=go.Figure(go.Heatmap(z=hdf.values,x=hdf.columns,y=hdf.index,colorscale=[[0,"#f0fdf4"],[0.15,"#fefce8"],[0.3,"#fef2f2"],[1,"#ef4444"]],text=hdf.values,texttemplate="%{text}%",textfont=dict(size=11,color="#0f172a"),zmin=0,zmax=100))
        fh.update_layout(**PLOT_LAYOUT,height=max(280,len(categories)*35+80),xaxis=dict(side="top"),yaxis=dict(autorange="reversed"))
        st.plotly_chart(fh,use_container_width=True)

    # ── RADAR + TOP RISK ──────────────────────────────────────────────────────
    st.divider()
    c3,c4=st.columns(2)
    with c3:
        section_label("CATEGORY RADAR — BAD RATE")
        sc=st.selectbox("Category",categories,key="ana_r")
        cd=edf[edf["Category"]==sc]
        if not cd.empty:
            vals=[]
            for idx,dn in enumerate(JUDGE_COL_NAMES):
                icc=JUDGE_CLASS_COLS[idx]; bad=JUDGE_BAD.get(icc,[])
                vals.append(cd[dn].isin(bad).sum()/max(1,len(cd))*100 if dn in cd.columns else 0)
            th=[jn[:12] for jn in JUDGE_NAMES]; th2=th+[th[0]]; v2=vals+[vals[0]]
            fr=go.Figure(go.Scatterpolar(r=v2,theta=th2,fill="toself",fillcolor="rgba(239,68,68,0.1)",line=dict(color="#ef4444",width=2)))
            fr.update_layout(polar=dict(radialaxis=dict(visible=True,range=[0,100],gridcolor="#e2e8f0",ticksuffix="%"),angularaxis=dict(gridcolor="#e2e8f0")),paper_bgcolor="white",height=360,margin=dict(l=40,r=40,t=20,b=20))
            st.plotly_chart(fr,use_container_width=True)
    with c4:
        section_label("TOP HIGH-RISK SUBTYPES")
        sr=edf.groupby("Subtype").apply(lambda g:(g["Status"]=="Fail").sum()/max(1,len(g))*100).sort_values(ascending=False).head(10)
        if not sr.empty:
            f4=go.Figure(go.Bar(x=sr.values,y=sr.index,orientation="h",marker_color=[("#ef4444" if v>=40 else "#f59e0b" if v>=20 else "#16a34a") for v in sr.values],text=[f"{v:.0f}%" for v in sr.values],textposition="outside"))
            f4.add_vline(x=20,line_dash="dash",line_color="#f59e0b")
            f4.update_layout(**PLOT_LAYOUT,height=360,xaxis=dict(range=[0,110],gridcolor="#f1f5f9",title="Fail %"))
            st.plotly_chart(f4,use_container_width=True)

    # ── SUBTYPE RISK TABLE ────────────────────────────────────────────────────
    st.divider(); section_label("SUBTYPE × JUDGE BAD RATE TABLE (%)")
    sjd=[]
    for sub in subtypes:
        sd=edf[edf["Subtype"]==sub]; r={"Subtype":sub,"Total":len(sd),"Fail Rate":round((sd["Status"]=="Fail").sum()/max(1,len(sd))*100,1)}
        for idx,(dn,jn) in enumerate(zip(JUDGE_COL_NAMES,JUDGE_NAMES)):
            icc=JUDGE_CLASS_COLS[idx]; bad=JUDGE_BAD.get(icc,[])
            r[jn]=round(sd[dn].isin(bad).sum()/max(1,len(sd))*100,1) if dn in sd.columns else 0
        sjd.append(r)
    sjdf=pd.DataFrame(sjd).sort_values("Fail Rate",ascending=False)
    def cp(v):
        try:
            x=float(v)
            if x>=40: return "background-color:#fee2e2;color:#dc2626;font-weight:700"
            if x>=20: return "background-color:#fef9c3;color:#ca8a04;font-weight:700"
            return "background-color:#dcfce7;color:#16a34a"
        except: return ""
    jpct=[jn for jn in JUDGE_NAMES if jn in sjdf.columns]
    st.dataframe(sjdf.style.applymap(cp,subset=["Fail Rate"]+jpct),use_container_width=True,height=fit_height(sjdf))
    _,srdl=st.columns([3,1])
    with srdl: green_download("⬇ Subtype Risk",to_excel_bytes(sjdf),"subtype_risk.xlsx","application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",key="dl_sr")

    # ── CO-OCCURRENCE ─────────────────────────────────────────────────────────
    st.divider(); section_label("JUDGE CO-OCCURRENCE — WHICH FAIL TOGETHER?")
    if len(fail_df)>0:
        cod=pd.DataFrame()
        for idx,(dn,jn) in enumerate(zip(JUDGE_COL_NAMES,JUDGE_NAMES)):
            icc=JUDGE_CLASS_COLS[idx]; bad=JUDGE_BAD.get(icc,[])
            cod[jn]=edf[dn].isin(bad).astype(int) if dn in edf.columns else 0
        cm=cod.corr().round(2)
        fco=go.Figure(go.Heatmap(z=cm.values,x=cm.columns,y=cm.index,colorscale=[[0,"#f0fdf4"],[0.3,"#fefce8"],[0.6,"#fef2f2"],[1,"#ef4444"]],text=cm.values,texttemplate="%{text}",textfont=dict(size=12,color="#0f172a"),zmin=0,zmax=1))
        fco.update_layout(**PLOT_LAYOUT,height=350,xaxis=dict(side="top"),yaxis=dict(autorange="reversed"))
        st.plotly_chart(fco,use_container_width=True)


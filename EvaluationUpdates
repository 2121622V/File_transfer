async def run_single_judge(judge_key, prompts_dict, row_dict):
    judge_cfg = prompts_dict.get(judge_key, {})
    if isinstance(judge_cfg, dict):
        sys_prompt = judge_cfg.get("system",""); user_tmpl = judge_cfg.get("user","")
    else:
        sys_prompt = None; user_tmpl = str(judge_cfg)
    user_prompt = (user_tmpl
        .replace("{{PROMPT}}", str(row_dict.get("Augmented Storyline","")))
        .replace("{{AI_RESPONSE}}", str(row_dict.get("Actual Output","")))
        .replace("{{EXPECTED_OUTPUT}}", str(row_dict.get("expected_output","")))
        .replace("{{ATTRIBUTE_NAME}}", str(row_dict.get("Category","")))
        .replace("{{ATTRIBUTE_VALUE}}", str(row_dict.get("Subtype","")))
        .replace("{{baseline}}", str(row_dict.get("expected_output","")))
        .replace("{{persona}}", str(row_dict.get("Actual Output","")))
        .replace("{{question}}", str(row_dict.get("Augmented Storyline",""))))
    return await call_llm(user_prompt, system=sys_prompt, json_mode=True)

def extract_judge_result(judge_idx, raw_result):
    if not raw_result or isinstance(raw_result, Exception):
        return {"classification": "UNKNOWN", "reasoning": "No response", "evidence": ""}
    res = raw_result
    jk = JUDGE_KEYS[judge_idx]
    classification = res.get("classification", "UNKNOWN")
    reasoning = res.get("reasoning", "")
    # Extract evidence field (different judges use different keys)
    if jk == "judge_1_demographic_parity":
        evidence = res.get("evidence", "")
    elif jk == "judge_2_equalized_odds":
        missing = res.get("missing_elements", [])
        evidence = ", ".join(missing) if missing else ""
    elif jk == "judge_3_refusal_rate":
        signals = res.get("refusal_signals", [])
        evidence = ", ".join(signals) if signals else ""
    elif jk == "judge_4_tone_parity":
        signals = res.get("tone_signals", [])
        extra = f"Warmth:{res.get('warmth_comparison','')}, Respect:{res.get('respect_comparison','')}, Formality:{res.get('formality_comparison','')}"
        evidence = (", ".join(signals) + " | " + extra) if signals else extra
    elif jk == "judge_5_stereotype":
        signals = res.get("stereotype_signals", [])
        atype = res.get("assumption_type", "none")
        evidence = (", ".join(signals) + f" [type:{atype}]") if signals else f"[type:{atype}]"
    else:
        evidence = ""
    return {"classification": classification, "reasoning": reasoning, "evidence": evidence}

async def evaluate_single_row(row_dict, prompts_dict):
    tasks = [run_single_judge(jk, prompts_dict, row_dict) for jk in JUDGE_KEYS]
    results = await asyncio.gather(*tasks, return_exceptions=True)
    row_out = {}
    for idx, raw in enumerate(results):
        parsed = extract_judge_result(idx, raw if not isinstance(raw, Exception) else None)
        row_out[JUDGE_CLASS_COLS[idx]]    = parsed["classification"]
        row_out[JUDGE_REASON_COLS[idx]]   = parsed["reasoning"]
        row_out[JUDGE_EVIDENCE_COLS[idx]] = parsed["evidence"]
    return row_out

def compute_global_status(row):
    for cc in JUDGE_CLASS_COLS:
        if cc in row and str(row.get(cc,"")) in ALL_BAD_VALS:
            return "Fail"
    return "Pass"

def compute_gap(series):
    return float(series.max()-series.min()) if len(series)>=2 else 0.0

def compute_all_gaps(edf, group_col="Subtype"):
    gap_rows = []
    for idx, (cc, jname, jcolor) in enumerate(zip(JUDGE_CLASS_COLS, JUDGE_NAMES, JUDGE_COLORS)):
        if cc not in edf.columns: continue
        bad_vals = JUDGE_BAD_VALS.get(cc, [])
        if not bad_vals: continue
        bad_rate = edf.groupby(group_col).apply(lambda g: g[cc].isin(bad_vals).sum()/max(1,len(g)))
        if len(bad_rate)<2: continue
        gv = compute_gap(bad_rate)
        if gv > 0:
            gap_rows.append({"Judge": jname, "Judge Color": jcolor, "Gap": gv,
                "Highest Group": bad_rate.idxmax(), "Highest Value": float(bad_rate.max()),
                "Lowest Group": bad_rate.idxmin(), "Lowest Value": float(bad_rate.min())})
    return gap_rows

def build_classification_column(edf):
    if "Classification" in edf.columns: return edf
    def _build(row):
        parts = []
        for cc, sl in zip(JUDGE_CLASS_COLS, JUDGE_SHORT_LABELS):
            if cc in row and str(row[cc]).strip() and str(row[cc])!="UNKNOWN":
                parts.append(f"{sl}:{row[cc]}")
        return " | ".join(parts) if parts else "—"
    edf["Classification"] = edf.apply(_build, axis=1)
    return edf


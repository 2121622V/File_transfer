def build_metrics_summary(edf):
    rows = []
    for cat in edf["Category"].dropna().unique():
        cd = edf[edf["Category"]==cat]
        row = {"Category": cat, "total": len(cd), "fail_count": (cd["Status"]=="Fail").sum()}
        for cc, jn in zip(JUDGE_CLASS_COLS, JUDGE_NAMES):
            if cc in cd.columns:
                bad = JUDGE_BAD_VALS.get(cc, [])
                row[f"{jn}_bad_rate"] = round(cd[cc].isin(bad).sum()/max(1,len(cd)), 3)
        row["failure_rate_pct"] = round(row["fail_count"]/max(1,row["total"])*100, 1)
        rows.append(row)
    return rows

async def generate_root_causes(prompts, metrics_summary):
    prompt = prompts.get("root_cause_analysis","").replace("{{metrics_summary}}", json.dumps(metrics_summary, indent=2))
    result = await call_llm(prompt, json_mode=True)
    return result if result and "root_causes" in result else {"root_causes": []}

async def generate_governance_recs(prompts, root_causes, metrics_summary):
    prompt = prompts.get("governance_recommendations","").replace("{{root_causes}}", json.dumps(root_causes, indent=2)).replace("{{metrics_summary}}", json.dumps(metrics_summary, indent=2))
    result = await call_llm(prompt, json_mode=True)
    return result if result and "recommendations" in result else {"recommendations": []}


def compute_fl_metrics(edf: pd.DataFrame) -> pd.DataFrame:
    """
    Evaluates each Actual Output row against 28 keyword-based fairlearn metrics.
    score  = matched_count / total_patterns  (0.0 – 1.0)
    status = Fail if score >= FL_THRESHOLD else Pass
    reason = matched keywords or 'No bias detected.'
    """
    if edf is None or len(edf) == 0:
        return pd.DataFrame()

    df = edf.reset_index(drop=True).copy()

    if "Actual Output" not in df.columns:
        st.error("'Actual Output' column not found.")
        return pd.DataFrame()

    reason_keys = [f"FL_Reason_{m.replace(' ','_')}" for m in FL_METRIC_NAMES]
    status_keys = [f"FL_Status_{m.replace(' ','_')}" for m in FL_METRIC_NAMES]

    for metric, rk, sk in zip(FL_METRIC_NAMES, reason_keys, status_keys):
        patterns = FL_METRICS[metric]
        scores, reasons, statuses = [], [], []
        for _, row in df.iterrows():
            text    = str(row.get("Actual Output", "")).lower()
            matched = [p for p in patterns if p in text]
            score   = round(min(len(matched) / max(len(patterns), 1), 1.0), 4)
            reasons.append(
                f"Detected: {', '.join(matched)}" if matched else "No bias detected.")
            statuses.append("Fail" if score >= FL_THRESHOLD else "Pass")
            scores.append(score)
        df[metric] = scores
        df[rk]     = reasons
        df[sk]     = statuses

    df["FL_Status"] = df.apply(
        lambda r: "Fail"
        if any(float(r.get(m, 0)) >= FL_THRESHOLD for m in FL_METRIC_NAMES)
        else "Pass",
        axis=1,
    )

    # store key lists on df attrs for easy access
    df.attrs["reason_keys"] = reason_keys
    df.attrs["status_keys"] = status_keys
    return df



def detect_fl_bias_per_row(edf: pd.DataFrame) -> pd.DataFrame:
    """
    Runs keyword/pattern detection on Actual Output text.
    For each of the 5 FL metric categories:
      - score = (matched keywords / total patterns) capped at 1.0
      - reason = matched keyword list or 'No bias detected'
      - status = Pass if score < FL_THRESHOLD else Fail
    Also uses Bias Type as sensitive feature for Fairlearn MetricFrame.
    Returns enriched DataFrame.
    """
    if edf is None or len(edf) == 0:
        return pd.DataFrame()

    df = edf.reset_index(drop=True).copy()

    if "Actual Output" not in df.columns:
        st.error("'Actual Output' column not found in evaluation results.")
        return pd.DataFrame()

    if "Bias Type" not in df.columns:
        df["Bias Type"] = "Unknown"

    # ── keyword detection per row ─────────────────────────────────────────────
    for metric, mk, rk, sk in zip(FL_METRIC_KEYS, FL_METRIC_KEYS,
                                   FL_REASON_KEYS, FL_STATUS_KEYS):
        patterns = FL_KEYWORD_PATTERNS[metric]
        scores, reasons, statuses = [], [], []

        for _, row in df.iterrows():
            text = str(row.get("Actual Output", "")).lower()
            matched = [p for p in patterns if p.lower() in text]
            score   = round(min(len(matched) / max(len(patterns), 1), 1.0), 4)
            reason  = (f"Detected: {', '.join(matched)}"
                       if matched else "No bias detected.")
            status  = "Fail" if score >= FL_THRESHOLD else "Pass"
            scores.append(score)
            reasons.append(reason)
            statuses.append(status)

        df[metric] = scores
        df[rk]     = reasons
        df[sk]     = statuses

    # ── global FL status ──────────────────────────────────────────────────────
    df["FL_Status"] = df.apply(
        lambda r: "Fail" if any(
            float(r.get(m, 0)) >= FL_THRESHOLD for m in FL_METRIC_KEYS
        ) else "Pass",
        axis=1,
    )

    return df


def build_fairlearn_section(fl_df: pd.DataFrame) -> dict:
    """
    Builds Fairlearn MetricFrame using keyword-detected Pass/Fail
    and Bias Type as the sensitive feature.
    Returns group-level metrics dict.
    """
    from fairlearn.metrics import (
        MetricFrame, selection_rate, true_positive_rate,
        false_positive_rate, false_negative_rate, true_negative_rate,
        count, demographic_parity_difference,
        demographic_parity_ratio, equalized_odds_difference,
    )

    if fl_df is None or len(fl_df) == 0:
        return {}

    results = {}

    for metric in FL_METRIC_KEYS:
        if metric not in fl_df.columns:
            continue

        y_true = np.ones(len(fl_df), dtype=int)
        y_pred = (fl_df[metric] < FL_THRESHOLD).astype(int).values  # 1=pass, 0=fail
        sf     = fl_df["Bias Type"].fillna("Unknown").astype(str).values

        try:
            mf = MetricFrame(
                metrics={
                    "pass_rate"          : selection_rate,
                    "fail_rate"          : lambda yt, yp, **kw: 1.0 - selection_rate(yt, yp, **kw),
                    "true_positive_rate" : true_positive_rate,
                    "false_positive_rate": false_positive_rate,
                    "false_negative_rate": false_negative_rate,
                    "true_negative_rate" : true_negative_rate,
                    "count"              : count,
                },
                y_true=y_true,
                y_pred=y_pred,
                sensitive_features=sf,
            )

            dpd = float(demographic_parity_difference(
                y_true=y_true, y_pred=y_pred, sensitive_features=sf))
            dpr = float(demographic_parity_ratio(
                y_true=y_true, y_pred=y_pred, sensitive_features=sf))
            eod = float(equalized_odds_difference(
                y_true=y_true, y_pred=y_pred, sensitive_features=sf))

            results[metric] = {
                "mf"     : mf,
                "overall": mf.overall.to_dict(),
                "dpd"    : dpd,
                "dpr"    : dpr,
                "eod"    : eod,
            }
        except Exception as e:
            st.warning(f"Fairlearn MetricFrame failed for {metric}: {e}")
            continue

    return results



# ══════════════════════════════════════════════════════════════════════════════
# STEP 3 — build_fairlearn_report() helper (place near other helpers, before page routing)
# ══════════════════════════════════════════════════════════════════════════════

def build_fairlearn_report(edf: pd.DataFrame) -> dict:
    """
    Builds MetricFrames using Fairlearn's own built-in metric functions.

    y_true = 1 for every row (ground truth: every test case should pass)
    y_pred = 1 if Status==Pass, 0 if Status==Fail

    Fairlearn's own metrics used directly — no custom closures:
      selection_rate         → pass rate per group
      true_positive_rate     → recall (of passing cases)
      false_positive_rate    → how often a failing case is predicted pass
      false_negative_rate    → how often a passing case is predicted fail
      true_negative_rate     → specificity
      count                  → group size

    Sensitive feature dimensions: A_Code, Category, Subtype, Bias Type
    Scalar disparity metrics: demographic_parity_difference,
                              demographic_parity_ratio,
                              equalized_odds_difference
    """
    from fairlearn.metrics import (
        MetricFrame,
        selection_rate,
        true_positive_rate,
        false_positive_rate,
        false_negative_rate,
        true_negative_rate,
        count,
        demographic_parity_difference,
        demographic_parity_ratio,
        equalized_odds_difference,
    )

    if edf is None or len(edf) == 0:
        return {}

    edf_r  = edf.reset_index(drop=True)

    # ── y_true / y_pred ───────────────────────────────────────────────────────
    # Every test case is expected to pass → y_true = 1 for all rows.
    # y_pred reflects whether the LLM output actually passed evaluation.
    y_true = np.ones(len(edf_r), dtype=int)
    y_pred = (edf_r["Status"] == "Pass").astype(int).values

    # ── Sensitive feature arrays ──────────────────────────────────────────────
    sf_code = edf_r["A_Code"].fillna("Unknown").values
    sf_cat  = edf_r["Category"].fillna("Unknown").values
    sf_sub  = edf_r["Subtype"].fillna("Unknown").values
    sf_bias = edf_r["Bias Type"].fillna("Unknown").values

    # ── Fairlearn built-in metrics dict — passed directly, no wrappers ────────
    # fail_rate is the only derived one (1 - selection_rate), kept as a lambda
    # because Fairlearn doesn't ship it by name.
    fairlearn_metrics = {
        "pass_rate"         : selection_rate,
        "fail_rate"         : lambda y_t, y_p, **kw: 1.0 - selection_rate(y_t, y_p, **kw),
        "true_positive_rate": true_positive_rate,    # TP / (TP+FN) — sensitivity
        "false_positive_rate": false_positive_rate,  # FP / (FP+TN)
        "false_negative_rate": false_negative_rate,  # FN / (FN+TP)
        "true_negative_rate": true_negative_rate,    # TN / (TN+FP) — specificity
        "count"             : count,                 # group size
    }

    # ── Build one MetricFrame per sensitive dimension ─────────────────────────
    def mf(sf):
        return MetricFrame(
            metrics           = fairlearn_metrics,
            y_true            = y_true,
            y_pred            = y_pred,
            sensitive_features= sf,
        )

    mf_code = mf(sf_code)
    mf_cat  = mf(sf_cat)
    mf_sub  = mf(sf_sub)
    mf_bias = mf(sf_bias)

    # ── Scalar disparity metrics (built-in, one call each) ────────────────────
    def scalar_disparities(sf):
        return {
            "demographic_parity_difference": demographic_parity_difference(
                y_true=y_true, y_pred=y_pred, sensitive_features=sf),
            "demographic_parity_ratio"     : demographic_parity_ratio(
                y_true=y_true, y_pred=y_pred, sensitive_features=sf),
            "equalized_odds_difference"    : equalized_odds_difference(
                y_true=y_true, y_pred=y_pred, sensitive_features=sf),
        }

    scalars_code = scalar_disparities(sf_code)
    scalars_cat  = scalar_disparities(sf_cat)
    scalars_sub  = scalar_disparities(sf_sub)
    scalars_bias = scalar_disparities(sf_bias)

    # ── Derived summary table — one row per A_Code ────────────────────────────
    bg      = mf_code.by_group.copy()
    overall = mf_code.overall.to_dict()

    summary_rows = []
    for code in bg.index:
        row = {"A_Code": code}
        for col in fairlearn_metrics:
            row[col] = round(float(bg.loc[code, col]), 4)
        ov_pr = overall.get("pass_rate", 1e-9) or 1e-9
        row["pass_rate_ratio"] = round(row["pass_rate"] / ov_pr, 3)
        row["n"] = int(bg.loc[code, "count"])
        summary_rows.append(row)
    summary_df = pd.DataFrame(summary_rows).sort_values("fail_rate", ascending=False)

    # ── Disparity table — difference between best/worst group per metric ──────
    metric_cols  = ["pass_rate","fail_rate","true_positive_rate",
                    "false_positive_rate","false_negative_rate","true_negative_rate"]
    disp_rows = []
    for m in metric_cols:
        grp   = bg[m].dropna()
        worst = grp.idxmax(); best = grp.idxmin()
        disp_rows.append({
            "Metric"      : m,
            "Worst Group" : worst,
            "Worst Value" : round(float(grp.max()), 4),
            "Best Group"  : best,
            "Best Value"  : round(float(grp.min()), 4),
            "Range"       : round(float(grp.max() - grp.min()), 4),
        })
    disparity_df = pd.DataFrame(disp_rows)

    return {
        "mf_code"       : mf_code,
        "mf_cat"        : mf_cat,
        "mf_sub"        : mf_sub,
        "mf_bias"       : mf_bias,
        "scalars_code"  : scalars_code,
        "scalars_cat"   : scalars_cat,
        "scalars_sub"   : scalars_sub,
        "scalars_bias"  : scalars_bias,
        "summary_df"    : summary_df,
        "disparity_df"  : disparity_df,
        "overall"       : overall,
        "metric_cols"   : metric_cols,
    }


# ══════════════════════════════════════════════════════════════════════════════
# STEP 4 — Full Fairlearn Report page (add this as a new elif in your page routing)
# ══════════════════════════════════════════════════════════════════════════════

elif page == "fairlearn":
    page_header("⚖️ Fairlearn Report",
                "Group fairness analysis across A_Code, Category, Subtype, and Bias Type using Microsoft Fairlearn.")

    if st.session_state.eval_df is None:
        st.warning("⬅ Complete the Evaluation step first."); st.stop()

    try:
        from fairlearn.metrics import MetricFrame
    except ImportError:
        st.error("❌ `fairlearn` is not installed. Run `pip install fairlearn>=0.10.0` and restart.")
        st.stop()

    edf = st.session_state.eval_df

    # ── Build / retrieve cached report ───────────────────────────────────────
    cache_key = f"fl_{len(edf)}_{edf[METRIC_KEYS].sum().sum():.4f}"
    if st.session_state.get("_fl_cache_key") != cache_key:
        with st.spinner("Computing Fairlearn MetricFrames across all group dimensions…"):
            report = build_fairlearn_report(edf)
        st.session_state["_fl_report"]    = report
        st.session_state["_fl_cache_key"] = cache_key
    else:
        report = st.session_state["_fl_report"]

    if not report:
        st.error("Could not build report — check eval data."); st.stop()

    summary_df   = report["summary_df"]
    disparity_df = report["disparity_df"]
    overall      = report["overall"]
    metric_cols  = report["metric_cols"]

    mf_code = report["mf_code"]
    mf_cat  = report["mf_cat"]
    mf_sub  = report["mf_sub"]
    mf_bias = report["mf_bias"]

    scalars_code = report["scalars_code"]
    scalars_cat  = report["scalars_cat"]
    scalars_sub  = report["scalars_sub"]
    scalars_bias = report["scalars_bias"]

    # ── Colour helpers ────────────────────────────────────────────────────────
    def dp_color(v):
        try:
            v = abs(float(v))
            return "#dc2626" if v > 0.1 else "#d97706" if v > 0.05 else "#16a34a"
        except: return "#94a3b8"

    def dp_label(v):
        try:
            v = abs(float(v))
            return "High" if v > 0.1 else "Med" if v > 0.05 else "Low"
        except: return "—"

    def style_range(val):
        try:
            v = float(val)
            if v >= 0.2: return "background-color:#fee2e2;color:#dc2626;font-weight:700"
            if v >= 0.1: return "background-color:#fef9c3;color:#ca8a04;font-weight:700"
            return "background-color:#dcfce7;color:#16a34a"
        except: return ""

    def style_ratio(val):
        try:
            v = float(val)
            if v >= 1.5: return "background-color:#fee2e2;color:#dc2626;font-weight:700"
            if v >= 1.2: return "background-color:#fef9c3;color:#ca8a04;font-weight:700"
            return "background-color:#dcfce7;color:#16a34a"
        except: return ""

    def style_pass_rate(val):
        try:
            v = float(val)
            if v < 0.4: return "background-color:#fee2e2;color:#dc2626;font-weight:700"
            if v < 0.7: return "background-color:#fef9c3;color:#ca8a04;font-weight:700"
            return "background-color:#dcfce7;color:#16a34a"
        except: return ""

    def style_dp(val):
        try:
            v = abs(float(val))
            if v > 0.1: return "background-color:#fee2e2;color:#dc2626;font-weight:700"
            if v > 0.05: return "background-color:#fef9c3;color:#ca8a04;font-weight:700"
            return "background-color:#dcfce7;color:#16a34a"
        except: return ""

    # ════════════════════════════════════════════════════════════════════════
    # SECTION A — Overall Fairness KPIs
    # ════════════════════════════════════════════════════════════════════════
    section_label("A · OVERALL FAIRNESS KPIs")
    st.markdown(
        '<div style="background:white;border:1px solid #e2e8f0;border-radius:12px;'
        'padding:20px 24px;margin-bottom:16px;border-left:4px solid #6366f1">',
        unsafe_allow_html=True)

    # ── Overall metrics row ───────────────────────────────────────────────────
    kpi1, kpi2, kpi3 = st.columns(3)
    kpi1.metric("Overall Pass Rate",  f"{overall.get('pass_rate',  0):.1%}")
    kpi2.metric("Overall Fail Rate",  f"{overall.get('fail_rate',  0):.1%}")
    kpi3.metric("True Positive Rate", f"{overall.get('true_positive_rate', 0):.3f}")

    kpi4, kpi5, kpi6 = st.columns(3)
    kpi4.metric("False Positive Rate", f"{overall.get('false_positive_rate', 0):.3f}")
    kpi5.metric("False Negative Rate", f"{overall.get('false_negative_rate', 0):.3f}")
    kpi6.metric("True Negative Rate",  f"{overall.get('true_negative_rate',  0):.3f}")

    st.markdown("<br>", unsafe_allow_html=True)

    # ── Scalar disparity KPI cards — one row per sensitive dimension ──────────
    for dim_label, scalars in [
        ("By A_Code",    scalars_code),
        ("By Category",  scalars_cat),
        ("By Subtype",   scalars_sub),
        ("By Bias Type", scalars_bias),
    ]:
        st.markdown(
            f'<div style="font-size:11px;font-weight:700;color:#6366f1;text-transform:uppercase;'
            f'letter-spacing:.07em;margin-bottom:8px">{dim_label}</div>',
            unsafe_allow_html=True)
        sc1, sc2, sc3 = st.columns(3)
        for col, (k, v) in zip([sc1, sc2, sc3], scalars.items()):
            c = dp_color(v)
            col.markdown(
                f'<div class="kpi-card" style="border-left-color:{c};margin-bottom:10px">'
                f'<div class="kpi-label">{k.replace("_"," ")}</div>'
                f'<div class="kpi-value" style="color:{c};font-size:20px">'
                f'{"—" if str(v)=="nan" else f"{v:.3f}"}</div>'
                f'<div style="font-size:10px;font-weight:700;color:{c}">{dp_label(v)}</div>'
                f'</div>', unsafe_allow_html=True)

    st.markdown('</div>', unsafe_allow_html=True)

    # ════════════════════════════════════════════════════════════════════════
    # SECTION B — Metric Disparity Table
    # ════════════════════════════════════════════════════════════════════════
    st.divider()
    dh, dl = st.columns([3, 1])
    with dh: section_label("B · METRIC DISPARITY — WORST VS BEST GROUP (by A_Code)")
    with dl:
        green_download("⬇ Download", to_excel_bytes(disparity_df),
                       "fl_disparity.xlsx",
                       "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                       key="dl_fl_disp")
    st.caption(
        "**Range** = worst − best group score.  "
        "**Ratio to Overall** = worst_group ÷ overall_mean.  "
        "**Dem. Parity Diff** = pass-rate gap between groups.  "
        "**Eq. Odds Diff** = true-positive rate gap between groups.")

    styled_disp = (
        disparity_df.style
        .applymap(style_range, subset=["Range"])
        .applymap(style_ratio, subset=["Ratio to Overall"])
        .applymap(style_dp,    subset=["Dem. Parity Diff", "Eq. Odds Diff"])
    )
    st.dataframe(styled_disp, use_container_width=True, height=fit_height(disparity_df))

    # ════════════════════════════════════════════════════════════════════════
    # SECTION C — Per-Group MetricFrame Tables (4 sensitive dimensions)
    # ════════════════════════════════════════════════════════════════════════
    st.divider()
    section_label("C · PER-GROUP METRIC SCORES — FAIRLEARN MetricFrame")
    st.caption("Each tab shows all Fairlearn built-in metrics sliced by a different sensitive feature dimension.")

    dim_tab1, dim_tab2, dim_tab3, dim_tab4 = st.tabs(
        ["By A_Code", "By Category", "By Subtype", "By Bias Type"])

    def render_mf_tab(mf, key_prefix):
        bg = mf.by_group.copy().reset_index()
        bg.columns = [str(c) for c in bg.columns]
        grp_col    = bg.columns[0]
        rate_cols  = [c for c in bg.columns if c != grp_col and c != "count"]

        th, tdl = st.columns([3, 1])
        with tdl:
            green_download("⬇ Download", to_excel_bytes(bg),
                           f"fl_{key_prefix}.xlsx",
                           "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
                           key=f"dl_mf_{key_prefix}")

        styled = bg.style.applymap(style_pass_rate,
                                   subset=["pass_rate"] if "pass_rate" in bg.columns else [])
        st.dataframe(styled, use_container_width=True, height=fit_height(bg, max_h=500))

        # Bar chart — pass_rate and fail_rate side by side per group
        fig = go.Figure()
        color_map = {
            "pass_rate": "#10b981", "fail_rate": "#ef4444",
            "true_positive_rate": "#6366f1", "false_positive_rate": "#f59e0b",
            "false_negative_rate": "#ec4899", "true_negative_rate": "#06b6d4",
        }
        for col in rate_cols:
            fig.add_trace(go.Bar(
                name=col.replace("_", " "),
                x=bg[grp_col].astype(str),
                y=bg[col].astype(float),
                marker_color=color_map.get(col, "#94a3b8"),
                opacity=0.85))
        fig.update_layout(
            **PLOT_LAYOUT, barmode="group", height=360,
            legend=dict(font_size=9, orientation="h", y=-0.30),
            xaxis=dict(tickangle=-35, tickfont_size=10),
            yaxis=dict(range=[0, 1.05], gridcolor="#f1f5f9", tickformat=".0%"))
        st.plotly_chart(fig, use_container_width=True)

    with dim_tab1: render_mf_tab(mf_code, "code")
    with dim_tab2: render_mf_tab(mf_cat,  "cat")
    with dim_tab3: render_mf_tab(mf_sub,  "sub")
    with dim_tab4: render_mf_tab(mf_bias, "bias")

    # ════════════════════════════════════════════════════════════════════════
    # SECTION D — Scalar Disparity Comparison across all 4 dimensions
    # ════════════════════════════════════════════════════════════════════════
    st.divider()
    section_label("D · SCALAR DISPARITY ACROSS ALL DIMENSIONS")
    st.caption(
        "Fairlearn's 3 scalar metrics compared across all 4 sensitive feature dimensions. "
        "Closer to 0 = fairer. Ratio closer to 1 = fairer.")

    scalar_names = ["demographic_parity_difference", "demographic_parity_ratio", "equalized_odds_difference"]
    dim_labels   = ["A_Code", "Category", "Subtype", "Bias Type"]
    dim_scalars  = [scalars_code, scalars_cat, scalars_sub, scalars_bias]

    for sn in scalar_names:
        vals = [s.get(sn, float("nan")) for s in dim_scalars]
        colors = [dp_color(v) for v in vals]
        fig_s = go.Figure(go.Bar(
            x=dim_labels, y=[abs(v) if not np.isnan(v) else 0 for v in vals],
            marker_color=colors,
            text=[f"{v:.3f}" if not np.isnan(v) else "—" for v in vals],
            textposition="outside"))
        fig_s.add_hline(y=0.10, line_dash="dash", line_color="#dc2626",
                        annotation_text="Action (0.10)")
        fig_s.add_hline(y=0.05, line_dash="dot",  line_color="#d97706",
                        annotation_text="Review (0.05)")
        fig_s.update_layout(
            **PLOT_LAYOUT, height=260,
            title_text=sn.replace("_", " ").title(),
            title_font_size=12,
            yaxis=dict(range=[0, max(0.3, max(abs(v) for v in vals if not np.isnan(v)) + 0.05)],
                       gridcolor="#f1f5f9"))
        st.plotly_chart(fig_s, use_container_width=True)

    # ════════════════════════════════════════════════════════════════════════
    # SECTION E — Pass Rate Parity bar per dimension
    # ════════════════════════════════════════════════════════════════════════
    st.divider()
    section_label("E · PASS RATE PARITY — BY GROUP")
    st.caption("Pass rate per group vs overall. Large spread = demographic parity violation.")

    for dim_label, mf_dim in [
        ("A_Code", mf_code), ("Category", mf_cat),
        ("Subtype", mf_sub), ("Bias Type", mf_bias),
    ]:
        bg_pr    = mf_dim.by_group.reset_index()
        bg_pr.columns = [str(c) for c in bg_pr.columns]
        grp_col  = bg_pr.columns[0]
        if "pass_rate" not in bg_pr.columns:
            continue
        pr_sorted   = bg_pr.sort_values("pass_rate")
        overall_pr  = float(mf_dim.overall["pass_rate"])
        bar_colors  = [
            "#ef4444" if v < 0.4 else "#f59e0b" if v < 0.7 else "#10b981"
            for v in pr_sorted["pass_rate"]
        ]
        fig_pr = go.Figure(go.Bar(
            x=pr_sorted["pass_rate"],
            y=pr_sorted[grp_col].astype(str),
            orientation="h", marker_color=bar_colors,
            text=pr_sorted["pass_rate"].apply(lambda v: f"{v*100:.1f}%"),
            textposition="outside"))
        fig_pr.add_vline(x=overall_pr, line_dash="dash", line_color="#6366f1",
                         annotation_text=f"Overall {overall_pr*100:.1f}%",
                         annotation_position="top right")
        pr_layout = {**PLOT_LAYOUT, "margin": dict(l=10, r=80, t=36, b=10)}
        fig_pr.update_layout(
            **pr_layout, title_text=f"Pass Rate — by {dim_label}", title_font_size=12,
            height=max(260, len(pr_sorted) * 24 + 60),
            xaxis=dict(range=[0, 1.25], tickformat=".0%", gridcolor="#f1f5f9"))
        st.plotly_chart(fig_pr, use_container_width=True)

    # ════════════════════════════════════════════════════════════════════════
    # SECTION F — Top-5 worst A_Codes by fail_rate
    # ════════════════════════════════════════════════════════════════════════
    st.divider()
    section_label("F · TOP WORST GROUPS BY FAIRLEARN METRICS")
    st.caption("Groups ranked by fail_rate, false_negative_rate, and false_positive_rate.")

    bg_code = mf_code.by_group.reset_index()
    bg_code.columns = [str(c) for c in bg_code.columns]
    grp_col = bg_code.columns[0]

    f1, f2, f3 = st.columns(3)
    for col, label, color, container in [
        ("fail_rate",           "Highest Fail Rate",          "#ef4444", f1),
        ("false_negative_rate", "Highest False Negative Rate","#f59e0b", f2),
        ("false_positive_rate", "Highest False Positive Rate","#6366f1", f3),
    ]:
        if col not in bg_code.columns:
            continue
        top5 = bg_code.nlargest(5, col)[[grp_col, col]]
        with container:
            st.markdown(
                f'<div style="background:white;border:1px solid #e2e8f0;border-radius:10px;'
                f'padding:12px 14px;border-top:3px solid {color}">'
                f'<div style="font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;'
                f'letter-spacing:.05em;margin-bottom:8px">{label}</div>',
                unsafe_allow_html=True)
            for _, r in top5.iterrows():
                v = float(r[col])
                c = "#dc2626" if v > 0.6 else "#d97706" if v > 0.3 else "#16a34a"
                st.markdown(
                    f'<div style="display:flex;justify-content:space-between;align-items:center;'
                    f'padding:4px 0;border-bottom:1px solid #f1f5f9">'
                    f'<span style="font-family:monospace;font-size:11px;color:#475569">{r[grp_col]}</span>'
                    f'<span style="font-size:12px;font-weight:700;color:{c}">{v:.1%}</span></div>',
                    unsafe_allow_html=True)
            st.markdown('</div>', unsafe_allow_html=True)

    # ════════════════════════════════════════════════════════════════════════
